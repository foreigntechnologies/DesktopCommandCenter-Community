<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="DesktopCommandCenter.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DesktopCommandCenter.UI"
    xmlns:tb="using:H.NotifyIcon"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DCC - Desktop Command Center"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <tb:TaskbarIcon
            x:Name="TrayIcon"
            IconSource="/Assets/AppIcon.ico"
            ToolTipText="Desktop Command Center"
            LeftClickCommand="{x:Bind TrayQuickAccessCommand}"
            DoubleClickCommand="{x:Bind TrayShowCommand}">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Atualização disponível" Click="TrayUpdate_Click">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE895;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Acesso rápido" Click="TrayShow_Click" />
                    <MenuFlyoutItem Text="Configurações" Click="TraySettings_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Documentação" Click="TrayDocs_Click" />
                    <MenuFlyoutItem Text="Reportar bug" Click="TrayBug_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Fechar" Click="TrayExit_Click" />
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>



        <Grid x:Name="AppTitleBar" Background="Transparent" Height="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Image Source="Assets/AppIcon.ico" Width="16" Height="16" Margin="12,0,12,0" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="DCC - Desktop Command Center" VerticalAlignment="Center" FontSize="12" />
        </Grid>

        <!--
            The Frame hosts pages for your application content. Add your UI to
            MainPage.xaml rather than here so you can use Page features such as
            navigation events and the Loaded lifecycle.
        -->
        <Frame x:Name="RootFrame" Grid.Row="1" />
    </Grid>
</Window>

