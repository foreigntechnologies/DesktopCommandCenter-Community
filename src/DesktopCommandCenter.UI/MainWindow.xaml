<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="DesktopCommandCenter.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DesktopCommandCenter.UI"
    xmlns:tb="using:H.NotifyIcon"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DCC - Desktop Command Center"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <tb:TaskbarIcon
            x:Name="TrayIcon"
            IconSource="/Assets/DCCAppIcon.ico"
            ToolTipText="Desktop Command Center"
            ForceCreate="True"
            ContextMenuMode="SecondWindow"
            LeftClickCommand="{x:Bind TrayQuickAccessCommand}"
            DoubleClickCommand="{x:Bind TrayShowCommand}">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem x:Name="TrayUpdateAvailableElement" Text="Atualização disponível" Click="TrayUpdate_Click">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE895;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:Name="TrayQuickAccessElement" Text="Acesso rápido" Click="TrayShow_Click"  />
                    <MenuFlyoutItem x:Name="TraySettingsElement" Text="Configurações" Click="TraySettings_Click"  />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:Name="TrayDocumentationElement" Text="Documentação" Click="TrayDocs_Click"  />
                    <MenuFlyoutItem x:Name="TrayReportBugElement" Text="Reportar bug" Click="TrayBug_Click"  />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:Name="TrayExitElement" Text="Fechar" Click="TrayExit_Click"  />
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>



        <StackPanel x:Name="AppTitleBar" Background="Transparent" Height="48" VerticalAlignment="Top" Orientation="Horizontal">
            <Image Source="Assets/StoreLogo.png" Width="16" Height="16" Margin="12,8,12,8" VerticalAlignment="Center" />
            <TextBlock Text="DCC - Desktop Command Center" VerticalAlignment="Center" FontSize="12" />
        </StackPanel>

        <!--
            The Frame hosts pages for your application content. Add your UI to
            MainPage.xaml rather than here so you can use Page features such as
            navigation events and the Loaded lifecycle.
        -->
        <Frame x:Name="RootFrame" Grid.Row="1" />

        <!-- FutureShell Terminal Overlay -->
        <Grid x:Name="TerminalOverlay" Grid.Row="0" Grid.RowSpan="2" 
              Visibility="Collapsed" Canvas.ZIndex="1000" 
              VerticalAlignment="Bottom" Height="400"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
              BorderBrush="{ThemeResource CardBorderBrush}"
              BorderThickness="0,1,0,0">
            
            <Grid.Resources>
                <Storyboard x:Name="TerminalSlideUpAnimation">
                    <DoubleAnimation Storyboard.TargetName="TerminalTransform" 
                                     Storyboard.TargetProperty="Y"
                                     To="0" Duration="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <ExponentialEase EasingMode="EaseOut" Exponent="5"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
                <Storyboard x:Name="TerminalSlideDownAnimation" Completed="TerminalSlideDownAnimation_Completed">
                    <DoubleAnimation Storyboard.TargetName="TerminalTransform" 
                                     Storyboard.TargetProperty="Y"
                                     To="400" Duration="0:0:0.25">
                        <DoubleAnimation.EasingFunction>
                            <ExponentialEase EasingMode="EaseIn" Exponent="5"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </Grid.Resources>

            <Grid.RenderTransform>
                <TranslateTransform x:Name="TerminalTransform" Y="400" />
            </Grid.RenderTransform>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid Background="{ThemeResource CardBackgroundBrush}" Padding="16,8">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE756;" FontSize="14" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />
                    <ComboBox x:Name="CmbShellSelector" Width="140" SelectedIndex="0" SelectionChanged="CmbShellSelector_SelectionChanged" Height="32" Padding="8,4">
                        <ComboBoxItem Content="PowerShell" Tag="powershell.exe" />
                        <ComboBoxItem Content="CMD" Tag="cmd.exe" />
                        <ComboBoxItem Content="Bash (WSL)" Tag="wsl.exe" />
                    </ComboBox>
                </StackPanel>
                <Button Content="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="10" 
                        Background="Transparent" BorderThickness="0" 
                        HorizontalAlignment="Right" Click="CloseTerminal_Click"
                        Width="28" Height="28" Padding="0"/>
            </Grid>

            <!-- Quick Commands Bar -->
            <Border Grid.Row="1" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="0,0,0,1">
                <ScrollViewer HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Hidden" VerticalScrollMode="Disabled" Padding="16,8">
                    <StackPanel x:Name="QuickCommandsPanel" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="MainWindowNewCommandElement" Content="+ Novo Comando" FontSize="12" Click="AddQuickCommand_Click" Background="Transparent" BorderBrush="{ThemeResource CardBorderBrush}"  />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <WebView2 x:Name="TerminalWebView" Grid.Row="2" Source="about:blank" 
                      DefaultBackgroundColor="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
        </Grid>
    </Grid>
</Window>

