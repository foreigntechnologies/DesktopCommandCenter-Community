<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DesktopCommandCenter.UI.Views.ProcessManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:DesktopCommandCenter.Application.Models"
    xmlns:local="using:DesktopCommandCenter.UI.Views"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="28,20,28,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="16" Margin="0,0,0,16">
            <TextBlock x:Name="TxtTitle" Text="Gerenciador de Processos Avançado" Style="{StaticResource TitleLargeTextBlockStyle}" FontWeight="SemiBold" />
            <AutoSuggestBox x:Name="BoxSearch" PlaceholderText="Pesquisar processos por nome..." QueryIcon="Find" 
                            Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                            MaxWidth="400" HorizontalAlignment="Left" />
            
            <Grid Padding="12,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtHeaderName" Grid.Column="0" Text="Nome do Processo" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="TxtHeaderPID" Grid.Column="1" Text="PID" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="TxtHeaderCPU" Grid.Column="2" Text="CPU (%)" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right"/>
                <TextBlock x:Name="TxtHeaderRAM" Grid.Column="3" Text="RAM (MB)" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right"/>
                <TextBlock x:Name="TxtHeaderStatus" Grid.Column="4" Text="Status" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right"/>
            </Grid>
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Processes, Mode=OneWay}" 
                  SelectionMode="Single" ShowsScrollingPlaceholders="False">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="12,8" />
                    <Setter Property="MinHeight" Value="40" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ProcessInfo">
                    <Grid>
                        <Grid.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem x:Name="FlyoutKillTree" Text="Matar Árvore de Processos" 
                                                Icon="Delete" 
                                                Foreground="#EF5350"
                                                Click="FlyoutKillTree_Click" 
                                                Tag="{x:Bind Id}" />
                            </MenuFlyout>
                        </Grid.ContextFlyout>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE7EF;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        
                        <TextBlock Grid.Column="1" Text="{x:Bind Id}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        
                        <TextBlock Grid.Column="2" Text="{x:Bind CpuUsageText}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="3" Text="{x:Bind RamUsageText}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        
                        <Border Grid.Column="4" Background="#1AEF5350" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Visibility="{x:Bind local:ProcessManagerPage.BoolToVis(IsOrphan)}">
                            <TextBlock Text="{x:Bind StatusText}" FontSize="11" FontWeight="SemiBold" Foreground="#EF5350" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Loading Overlay -->
        <ProgressRing Grid.Row="1" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="40" Height="40" />
    </Grid>
</Page>
