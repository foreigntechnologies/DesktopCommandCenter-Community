<Window
    x:Class="DesktopCommandCenter.UI.Views.FutureShellWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="FutureShell">

    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom TitleBar Content -->
        <Grid x:Name="AppTitleBar" Height="32" Background="Transparent" Padding="12,0" Canvas.ZIndex="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <Image Source="ms-appx:///Assets/FutureShell-IconSemTexto.png" Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="FutureShell" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
        </Grid>

        <!-- TabView for the Terminals -->
        <TabView x:Name="TerminalTabView" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                 AddTabButtonClick="TabView_AddTabButtonClick"
                 TabCloseRequested="TabView_TabCloseRequested"
                 SelectionChanged="TabView_SelectionChanged">
            <TabView.TabStripHeader>
                <Grid Width="200" /> <!-- Space for TitleBar content -->
            </TabView.TabStripHeader>
        </TabView>
    </Grid>
</Window>
