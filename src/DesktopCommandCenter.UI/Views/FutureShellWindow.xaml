<Window
    x:Class="DesktopCommandCenter.UI.Views.FutureShellWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="FutureShell">

    <Grid Background="#202020" RequestedTheme="Dark">
        <!-- TabView for the Terminals -->
        <TabView x:Name="TerminalTabView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                 AddTabButtonClick="TabView_AddTabButtonClick"
                 TabCloseRequested="TabView_TabCloseRequested"
                 SelectionChanged="TabView_SelectionChanged">
            
            <TabView.TabStripHeader>
                <Grid x:Name="AppTitleBar" Background="Transparent" Padding="12,0,12,0" VerticalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <Image Source="ms-appx:///Assets/FutureShell-IconSemTexto.png" Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="FutureShell" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </Grid>
            </TabView.TabStripHeader>
            
            <TabView.TabStripFooter>
                <!-- This empty area acts as a flexible drag region and keeps tabs away from window buttons -->
                <Grid x:Name="RightDragRegion" Background="Transparent" HorizontalAlignment="Stretch" MinWidth="200" />
            </TabView.TabStripFooter>
        </TabView>
    </Grid>
</Window>
