<Window
    x:Class="DesktopCommandCenter.UI.Views.FutureShellWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="FutureShell">

    <Grid Background="Transparent" RequestedTheme="Dark">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom TitleBar Content -->
        <StackPanel x:Name="AppTitleBar" Height="32" Background="Transparent" Padding="12,0" Orientation="Horizontal">
            <Image Source="ms-appx:///Assets/FutureShell-IconSemTexto.png" Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center" />
            <TextBlock Text="FutureShell" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
        </StackPanel>

        <!-- WebView2 for the Terminal UI -->
        <WebView2 x:Name="TerminalWebView" Grid.Row="1" Source="about:blank" 
                  DefaultBackgroundColor="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
    </Grid>
</Window>
