<Page
    x:Class="DesktopCommandCenter.UI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:DesktopCommandCenter.UI.Controls"
    xmlns:helpers="using:DesktopCommandCenter.UI.Helpers"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Background="Transparent">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Padding="32" Spacing="24">
                
                <!-- 1. HEADER (Health Status) -->
                <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Left">
                            <FontIcon x:Name="HealthIcon" Glyph="&#xE73E;" FontSize="32" Foreground="{ThemeResource SystemFillColorSuccessBrush}" VerticalAlignment="Center" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="DashGreeting" Text="Bom dia, Gustavo" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock x:Name="HealthStatusText" Text="Seu computador está saudável." FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock x:Name="DashDateText" Text="..." FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="DashTimeText" Text="..." FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 2. METRICS (CPU, RAM, GPU, Rede) -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <controls:InfoCard Grid.Column="0" Title="CPU" IconGlyph="&#xE968;">
                        <TextBlock x:Name="CpuText" Text="0%" FontSize="28" FontWeight="Bold" />
                    </controls:InfoCard>
                    <controls:InfoCard Grid.Column="1" Title="RAM" IconGlyph="&#xE964;">
                        <TextBlock x:Name="RamText" Text="0%" FontSize="28" FontWeight="Bold" />
                    </controls:InfoCard>
                    <controls:InfoCard Grid.Column="2" Title="GPU" IconGlyph="&#xE945;">
                        <TextBlock Text="3%" FontSize="28" FontWeight="Bold" />
                    </controls:InfoCard>
                    <controls:InfoCard Grid.Column="3" Title="Rede" IconGlyph="&#xE839;">
                        <TextBlock x:Name="NetworkText" Text="0%" FontSize="28" FontWeight="Bold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                    </controls:InfoCard>
                </Grid>

                <!-- 3. TIMELINE & AI ACTIONS -->
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <!-- Timeline Inteligente -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{x:Bind helpers:LocalizationHelper.GetLocalized('Dash_TimelineTitle')}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <Border Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                                BorderThickness="1" CornerRadius="8" Padding="8">
                            <ListView x:Name="TimelineList" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="30" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Time}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            <FontIcon Grid.Column="1" Glyph="{Binding Icon}" Foreground="{Binding IconColor}" FontSize="14" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding Message}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                    </Grid>

                    <!-- Ações IA -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{x:Bind helpers:LocalizationHelper.GetLocalized('Dash_AIActionsTitle')}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <Border Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                                BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <FontIcon Glyph="&#xEC19;" FontSize="24" Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                                    <TextBlock x:Name="AIPromptTitle" Text="{x:Bind helpers:LocalizationHelper.GetLocalized('Dash_AIPromptTitle')}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock x:Name="AIPromptMessage" Text="{x:Bind helpers:LocalizationHelper.GetLocalized('Dash_AIPromptMessage')}" TextWrapping="Wrap" />
                                <StackPanel Spacing="8" x:Name="AIActionsContainer">
                                    <Button x:Name="AIPromptBtn1" Content="{x:Bind helpers:LocalizationHelper.GetLocalized('Dash_AIBtn1')}" HorizontalAlignment="Stretch" Click="AIPromptBtn1_Click" />
                                    <Button x:Name="AIPromptBtn2" Content="{x:Bind helpers:LocalizationHelper.GetLocalized('Dash_AIBtn2')}" HorizontalAlignment="Stretch" Click="AIPromptBtn2_Click" />
                                    <Button x:Name="AIPromptBtn3" Content="{x:Bind helpers:LocalizationHelper.GetLocalized('Dash_AIBtn3')}" HorizontalAlignment="Stretch" Click="AIPromptBtn3_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- 4. PILLARS (FutureShell, ChatFT, Desenvolvimento) -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <controls:InfoCard Grid.Column="0" Title="FutureShell" IconGlyph="&#xE756;">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{x:Bind helpers:LocalizationHelper.GetLocalized('Dash_LatestCommands')}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="FutureShellCmd1" Text="{x:Bind helpers:LocalizationHelper.GetLocalized('Dash_CmdWinget')}" FontFamily="Consolas" />
                            <TextBlock x:Name="FutureShellCmd2" Text="{x:Bind helpers:LocalizationHelper.GetLocalized('Dash_CmdGit')}" FontFamily="Consolas" />
                            <TextBlock x:Name="FutureShellCmd3" Text="{x:Bind helpers:LocalizationHelper.GetLocalized('Dash_CmdNpm')}" FontFamily="Consolas" />
                        </StackPanel>
                    </controls:InfoCard>

                    <controls:InfoCard Grid.Column="1" Title="ChatFT" IconGlyph="&#xE92E;">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{x:Bind helpers:LocalizationHelper.GetLocalized('Dash_LatestChats')}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="ChatFT1" Text="{x:Bind helpers:LocalizationHelper.GetLocalized('Dash_Chat1')}" />
                            <TextBlock x:Name="ChatFT2" Text="{x:Bind helpers:LocalizationHelper.GetLocalized('Dash_Chat2')}" />
                            <TextBlock x:Name="ChatFT3" Text="{x:Bind helpers:LocalizationHelper.GetLocalized('Dash_Chat3')}" />
                        </StackPanel>
                    </controls:InfoCard>

                    <controls:InfoCard Grid.Column="2" Title="{x:Bind helpers:LocalizationHelper.GetLocalized('Dash_DevTitle')}" IconGlyph="&#xE943;">
                        <ScrollViewer MaxHeight="110" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                            <ItemsControl x:Name="DevToolsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <TextBlock Text="{Binding Name}" HorizontalAlignment="Left" />
                                            <TextBlock Text="{Binding Status}" HorizontalAlignment="Right" Foreground="{Binding StatusColor}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </controls:InfoCard>
                </Grid>

                <!-- 5. STORAGE & SYSTEM SHORTCUTS -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="0,0,0,8">
                    <StackPanel Orientation="Horizontal" Spacing="24">
                        
                        <StackPanel Spacing="12">
                            <TextBlock x:Name="StorageTitle" Grid.Row="0" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <ItemsControl x:Name="DrivesItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="16" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <controls:InfoCard Title="{Binding Title}" IconGlyph="{Binding IconGlyph}" Width="250">
                                            <StackPanel Spacing="8">
                                                <ProgressBar Value="{Binding PercentageUsed}" Maximum="100" />
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding UsedText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding TotalText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                                        <TextBlock Text="{Binding FreeText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </controls:InfoCard>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- SYSTEM SHORTCUTS -->
                        <StackPanel Spacing="12">
                            <TextBlock x:Name="SysShortcutsTitle" Grid.Row="0" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <Grid Width="200" VerticalAlignment="Top">
                                    <controls:InfoCard x:Name="CardSettings" IconGlyph="&#xE713;" />
                                    <Button Padding="0" BorderThickness="0" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="BtnOpenSettings_Click" />
                                </Grid>

                                <Grid Width="200" VerticalAlignment="Top">
                                    <controls:InfoCard x:Name="CardEnvVars" IconGlyph="&#xE8B1;" />
                                    <Button Padding="0" BorderThickness="0" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="BtnOpenEnvVars_Click" />
                                </Grid>

                                <Grid Width="200" VerticalAlignment="Top">
                                    <controls:InfoCard x:Name="CardRegEdit" IconGlyph="&#xE90C;" />
                                    <Button Padding="0" BorderThickness="0" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="BtnOpenRegEdit_Click" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
