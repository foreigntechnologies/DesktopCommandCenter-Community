<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="DesktopCommandCenter.UI.Views.QuickAccessWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="DCC - Acesso Rápido">

    <Grid Background="Transparent">
        <!-- Borda arredondada com Acrylic -->
        <Border
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Cabeçalho -->
                <Grid Grid.Row="0" Padding="18,16,14,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Text="Acesso rápido"
                        FontSize="15"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    <Button
                        x:Name="BtnMais"
                        Grid.Column="1"
                        Click="BtnMais_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        CornerRadius="6"
                        Padding="12,5">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Mais" FontSize="13" />
                            <FontIcon Glyph="&#xE76C;" FontSize="11" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Grade de Ferramentas 3x3 -->
                <Grid Grid.Row="1" Padding="10,4,10,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Linha 1 -->
                    <Button x:Name="BtnColorPicker" Grid.Row="0" Grid.Column="0" Click="Tool_Click" Tag="ColorPicker" Style="{StaticResource QuickToolButtonStyle}">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xEF3C;" FontSize="28" Foreground="#0099DA" />
                            <TextBlock Text="Seletor de Cores" TextWrapping="Wrap" TextAlignment="Center" FontSize="11.5" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnClipboard" Grid.Row="0" Grid.Column="1" Click="Tool_Click" Tag="Clipboard" Style="{StaticResource QuickToolButtonStyle}">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xF0E3;" FontSize="28" Foreground="#7B68EE" />
                            <TextBlock Text="Clipboard" TextWrapping="Wrap" TextAlignment="Center" FontSize="11.5" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnNotes" Grid.Row="0" Grid.Column="2" Click="Tool_Click" Tag="Notes" Style="{StaticResource QuickToolButtonStyle}">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE70B;" FontSize="28" Foreground="#FFB347" />
                            <TextBlock Text="Notas" TextWrapping="Wrap" TextAlignment="Center" FontSize="11.5" />
                        </StackPanel>
                    </Button>

                    <!-- Linha 2 -->

                    <Button x:Name="BtnTradutor" Grid.Row="1" Grid.Column="1" Click="Tool_Click" Tag="Tradutor" Style="{StaticResource QuickToolButtonStyle}">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xF2B7;" FontSize="28" Foreground="#26C6DA" />
                            <TextBlock Text="Tradutor" TextWrapping="Wrap" TextAlignment="Center" FontSize="11.5" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnTemporizador" Grid.Row="1" Grid.Column="2" Click="Tool_Click" Tag="Temporizador" Style="{StaticResource QuickToolButtonStyle}">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE916;" FontSize="28" Foreground="#FF7043" />
                            <TextBlock Text="Temporizador" TextWrapping="Wrap" TextAlignment="Center" FontSize="11.5" />
                        </StackPanel>
                    </Button>

                    <!-- Linha 3 -->
                    <Button x:Name="BtnPrompts" Grid.Row="2" Grid.Column="0" Click="Tool_Click" Tag="Prompts" Style="{StaticResource QuickToolButtonStyle}">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE8BD;" FontSize="28" Foreground="#AB47BC" />
                            <TextBlock Text="Prompts IA" TextWrapping="Wrap" TextAlignment="Center" FontSize="11.5" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnPesquisa" Grid.Row="2" Grid.Column="1" Click="Tool_Click" Tag="PesquisaUniversal" Style="{StaticResource QuickToolButtonStyle}">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE721;" FontSize="28" Foreground="#42A5F5" />
                            <TextBlock Text="Pesquisa" TextWrapping="Wrap" TextAlignment="Center" FontSize="11.5" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnAutomacoes" Grid.Row="2" Grid.Column="2" Click="Tool_Click" Tag="Automacoes" Style="{StaticResource QuickToolButtonStyle}">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE9F5;" FontSize="28" Foreground="#EF5350" />
                            <TextBlock Text="Automações" TextWrapping="Wrap" TextAlignment="Center" FontSize="11.5" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Barra inferior -->
                <Border
                    Grid.Row="2"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Atalhos de ação -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                            <Button x:Name="BtnDocs" Click="BtnDocs_Click" Style="{StaticResource QuickBarButtonStyle}" ToolTipService.ToolTip="Documentação">
                                <FontIcon Glyph="&#xE7C3;" FontSize="16" />
                            </Button>
                            <Button x:Name="BtnBug" Click="BtnBug_Click" Style="{StaticResource QuickBarButtonStyle}" ToolTipService.ToolTip="Reportar bug">
                                <FontIcon Glyph="&#xEBE8;" FontSize="16" />
                            </Button>
                            <Button x:Name="BtnSettings" Click="BtnSettings_Click" Style="{StaticResource QuickBarButtonStyle}" ToolTipService.ToolTip="Configurações">
                                <FontIcon Glyph="&#xE713;" FontSize="16" />
                            </Button>
                        </StackPanel>

                        <!-- Badge de versão/status -->
                        <TextBlock
                            x:Name="TxtVersion"
                            Grid.Column="1"
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
