<Page
    x:Class="DesktopCommandCenter.UI.Views.AuthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:DesktopCommandCenter.UI.Helpers"
    mc:Ignorable="d">

    <Grid Padding="24">
        <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500">
            <TextBlock Text="Licenciamento &amp; Nuvem" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" Margin="0,0,0,8" />
            <TextBlock Text="O Command Center funciona offline e de graça. Crie uma conta ou faça login apenas se desejar desbloquear as funcionalidades avançadas." 
                       TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,16" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <!-- Estado DESLOGADO -->
            <StackPanel Spacing="16" Visibility="{x:Bind ViewModel.IsNotLoggedIn, Mode=OneWay}" Width="350">
                <Button Command="{x:Bind ViewModel.LoginWithGoogleCommand}" HorizontalAlignment="Stretch" Padding="12" Background="{ThemeResource SystemControlBackgroundAccentBrush}" Foreground="White">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Viewbox Width="18" Height="18" VerticalAlignment="Center">
                            <Path Data="M12.545,10.239v3.821h5.445c-0.712,2.315-2.647,3.972-5.445,3.972c-3.332,0-6.033-2.701-6.033-6.032s2.701-6.032,6.033-6.032c1.498,0,2.866,0.549,3.921,1.453l2.814-2.814C17.503,2.988,15.139,2,12.545,2C7.021,2,2.532,6.477,2.532,12s4.489,10,10.013,10c8.396,0,10.249-7.85,9.426-11.761H12.545z" Fill="White"/>
                        </Viewbox>
                        <TextBlock Text="Continuar com o Google" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                
                <Button Command="{x:Bind ViewModel.LoginWithGitHubCommand}" HorizontalAlignment="Stretch" Padding="12">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Viewbox Width="18" Height="18" VerticalAlignment="Center">
                            <Path Data="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" Fill="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Viewbox>
                        <TextBlock Text="Continuar com o GitHub" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Separador -->
                <Grid Margin="0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0.5" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="ou use e-mail" Margin="12,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" VerticalAlignment="Center" />
                    <Border Grid.Column="2" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0.5" VerticalAlignment="Center" />
                </Grid>

                <!-- Campos de E-mail/Senha -->
                <TextBox Header="E-mail" 
                         Text="{x:Bind ViewModel.Email, Mode=TwoWay}" 
                         PlaceholderText="seuemail@exemplo.com" />
                
                <PasswordBox x:Name="PasswordInput" 
                             Header="Senha" 
                             PasswordChanged="PasswordInput_PasswordChanged" 
                             PlaceholderText="Sua senha" />

                <Grid ColumnSpacing="12" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Entrar" Command="{x:Bind ViewModel.LoginWithEmailCommand}" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" Padding="8" />
                    <Button Grid.Column="1" Content="Criar Conta" Command="{x:Bind ViewModel.RegisterWithEmailCommand}" HorizontalAlignment="Stretch" Padding="8" />
                </Grid>
            </StackPanel>

            <!-- Estado LOGADO (Painel de Upgrade) -->
            <StackPanel Spacing="16" Visibility="{x:Bind ViewModel.IsLoggedIn, Mode=OneWay}">
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="24">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Desktop Command Center PRO" Style="{StaticResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" />
                        <TextBlock Text="🚀 Desbloqueie o histórico infinito e automações nativas." TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                        
                        <Grid ColumnSpacing="16" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Assinatura Community -->
                            <Border Grid.Column="0" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Community" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Grátis" Foreground="{ThemeResource SystemControlBackgroundAccentBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Ferramentas essenciais para uso local e código aberto." FontSize="12" TextWrapping="Wrap" TextAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- Assinatura Enterprise -->
                            <Border Grid.Column="1" Background="{ThemeResource SystemControlBackgroundAccentBrush}" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Enterprise" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="R$ 39,90/mês" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Desbloqueia automações na nuvem, plugins premium e integrações de inteligência artificial." FontSize="12" TextWrapping="Wrap" Foreground="White" TextAlignment="Center"/>
                                    <Button Command="{x:Bind ViewModel.UpgradeMonthlyCommand}" Content="Assinar" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <HyperlinkButton Content="Gerenciar minha Assinatura" Command="{x:Bind ViewModel.OpenCustomerPortalCommand}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                        <Button Content="Sair da Conta" Command="{x:Bind ViewModel.LogoutCommand}" HorizontalAlignment="Center" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Page>
