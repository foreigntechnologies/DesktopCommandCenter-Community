<Page
    x:Class="DesktopCommandCenter.UI.Views.AuthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="24">
        <ScrollViewer>
            <StackPanel>
                <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                            MaxWidth="480" Margin="0,40,0,40">

                <!-- Header -->
                <StackPanel Spacing="8" HorizontalAlignment="Center" Margin="0,0,0,40">
                    <FontIcon Glyph="&#xE7BF;" FontSize="48"
                              Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                              HorizontalAlignment="Center" />
                    <TextBlock x:Name="TxtAuthTitle" Text="Licenciamento &amp; Nuvem" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center"  />
                    <TextBlock x:Name="TxtAuthDesc" Text="O DCC funciona 100% offline e gratuito. Faça login apenas para desbloquear os recursos PRO." TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"  />
                </StackPanel>

                <!-- Mensagens globais (Loading / Erro / Sucesso) -->
                <StackPanel Spacing="12" Margin="0,0,0,20">
                    <StackPanel x:Name="LoadingPanel" Spacing="12" HorizontalAlignment="Center"
                                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ProgressRing IsActive="True" Width="32" Height="32" HorizontalAlignment="Center" />
                        <TextBlock x:Name="TxtLoading" Text="Processando requisição... (se você fechou o navegador, clique em Cancelar)" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="300"  />
                        <HyperlinkButton x:Name="AuthBtnCancelElement" Content="Cancelar" Command="{x:Bind ViewModel.CancelLoginCommand}" HorizontalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"  />
                    </StackPanel>

                    <Border x:Name="ErrorPanel" CornerRadius="8" Padding="12,10"
                            Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                            Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE783;" FontSize="16"
                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       TextWrapping="Wrap" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="SuccessPanel" CornerRadius="8" Padding="12,10"
                            Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                            Visibility="{x:Bind ViewModel.HasSuccess, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE73E;" FontSize="16"
                                      Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                       Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                       TextWrapping="Wrap" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ══ PAINEL NÃO LOGADO ══ -->
                <StackPanel x:Name="NotLoggedInPanel" Spacing="16" Visibility="{x:Bind ViewModel.IsNotLoggedIn, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                    <!-- Google -->
                    <Button Command="{x:Bind ViewModel.LoginWithGoogleCommand}"
                            IsEnabled="{x:Bind ViewModel.IsNotLoading, Mode=OneWay}"
                            HorizontalAlignment="Stretch" Padding="14,12"
                            CornerRadius="8">
                        <Grid HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <!-- Google logo SVG -->
                            <Viewbox Grid.Column="0" Width="20" Height="20" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" Fill="#4285F4"/>
                                    <Path Data="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" Fill="#34A853"/>
                                    <Path Data="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" Fill="#FBBC05"/>
                                    <Path Data="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" Fill="#EA4335"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Grid.Column="1" x:Name="TxtGoogle" Text="Continuar com o Google" VerticalAlignment="Center" HorizontalAlignment="Left" FontWeight="SemiBold" FontSize="14"  />
                        </Grid>
                    </Button>

                    <!-- GitHub -->
                    <Button Command="{x:Bind ViewModel.LoginWithGitHubCommand}"
                            IsEnabled="{x:Bind ViewModel.IsNotLoading, Mode=OneWay}"
                            HorizontalAlignment="Stretch" Padding="14,12"
                            CornerRadius="8">
                        <Grid HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <Viewbox Grid.Column="0" Width="20" Height="20" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Path Data="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
                                      Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                            </Viewbox>
                            <TextBlock Grid.Column="1" x:Name="TxtGitHub" Text="Continuar com o GitHub" VerticalAlignment="Center" HorizontalAlignment="Left" FontWeight="SemiBold" FontSize="14"  />
                        </Grid>
                    </Button>

                    <!-- Botões de login movidos para cima para manter os erros abaixo -->

                    <!-- Nota de privacidade -->
                    <TextBlock FontSize="11" TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Margin="0,8,0,0">
                        <Run x:Name="TxtTermsPrefix" >Ao continuar, você aceita os </Run>
                        <Hyperlink NavigateUri="https://foreigntechnologies.com.br/legal/terms">
                            <Run x:Name="HypTerms" >Termos de Uso</Run>
                        </Hyperlink>
                        <Run x:Name="TxtTermsMid" > e a </Run>
                        <Hyperlink NavigateUri="https://foreigntechnologies.com.br/legal/privacy">
                            <Run x:Name="HypPrivacy" >Política de Privacidade</Run>
                        </Hyperlink>
                        <Run x:Name="TxtTermsSuffix" >.</Run>
                    </TextBlock>
                </StackPanel>

                <!-- ══ PAINEL LOGADO ══ -->
                <Border x:Name="LoggedInPanel" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1"
                        CornerRadius="16" Padding="32,32,32,24"
                        Visibility="{x:Bind ViewModel.IsLoggedIn, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        MaxWidth="460">
                    <StackPanel Spacing="24">

                        <!-- User avatar area -->
                        <StackPanel Spacing="12" HorizontalAlignment="Center">
                            <Grid Margin="0,0,0,24">
                                <PersonPicture ProfilePicture="{x:Bind ConvertToImageSource(ViewModel.ProfilePhotoUrl), Mode=OneWay}"
                                               Width="96" Height="96" HorizontalAlignment="Center"/>
                            </Grid>
                                
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <!-- Nome do Usuário -->
                                <TextBlock x:Name="TxtUserName" Text="{x:Bind ViewModel.UserName, Mode=OneWay}"
                                           FontWeight="Bold" HorizontalAlignment="Center" FontSize="18"
                                           TextWrapping="Wrap" TextAlignment="Center" MaxWidth="380"
                                           Visibility="{x:Bind ViewModel.HasUserName, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                                <!-- Somente E-mail padrão (se não tiver nenhuma rede) -->
                                <TextBlock x:Name="DefaultEmailText" Text="{x:Bind ViewModel.UserEmail, Mode=OneWay}"
                                           FontWeight="SemiBold" HorizontalAlignment="Center" FontSize="15"
                                           TextWrapping="Wrap" TextAlignment="Center" MaxWidth="380"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Visibility="{x:Bind ViewModel.HasNoGoogleLinked, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                                <!-- Google -->
                                <StackPanel x:Name="GoogleEmailPanel" Orientation="Horizontal" Spacing="8" Visibility="{x:Bind ViewModel.HasGoogleLinked, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" HorizontalAlignment="Center">
                                    <Viewbox Width="18" Height="18">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" Fill="#4285F4"/>
                                            <Path Data="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" Fill="#34A853"/>
                                            <Path Data="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" Fill="#FBBC05"/>
                                            <Path Data="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" Fill="#EA4335"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="{x:Bind ViewModel.GoogleEmail, Mode=OneWay}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- GitHub -->
                                <StackPanel x:Name="GitHubEmailPanel" Orientation="Horizontal" Spacing="8" Visibility="{x:Bind ViewModel.HasGitHubLinked, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" HorizontalAlignment="Center">
                                    <Viewbox Width="18" Height="18">
                                        <Path Data="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
                                              Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                                    </Viewbox>
                                    <TextBlock Text="{x:Bind ViewModel.GitHubEmail, Mode=OneWay}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- Microsoft -->
                                <StackPanel x:Name="MicrosoftEmailPanel" Orientation="Horizontal" Spacing="8" Visibility="{x:Bind ViewModel.HasMicrosoftLinked, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" HorizontalAlignment="Center">
                                    <Viewbox Width="18" Height="18">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M11.4 24H0V12.6h11.4V24zM24 24H12.6V12.6H24V24zM11.4 11.4H0V0h11.4v11.4zm12.6 0H12.6V0H24v11.4z" Fill="#00A4EF"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="{x:Bind ViewModel.MicrosoftEmail, Mode=OneWay}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                            
                            <Border Background="{ThemeResource ControlFillColorSecondaryBrush}" 
                                    CornerRadius="12" Padding="14,6" HorizontalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.PlanDisplayText, Mode=OneWay}"
                                           Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                           FontSize="12" FontWeight="Bold" />
                            </Border>
                        </StackPanel>

                        <Border BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Margin="0,4" />

                        <!-- Vinculação de Contas -->
                        <StackPanel Spacing="16">
                            <TextBlock x:Name="TxtLinkAccountsTitle" Text="Vincular contas adicionais:" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                            
                            <StackPanel Spacing="8">
                                <Button Command="{x:Bind ViewModel.LinkGoogleCommand}" 
                                        Visibility="{x:Bind ViewModel.CanLinkGoogle, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" 
                                        HorizontalAlignment="Stretch" Padding="8" CornerRadius="6">
                                    <Grid HorizontalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Viewbox Grid.Column="0" Width="16" Height="16" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" Fill="#4285F4"/>
                                                <Path Data="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" Fill="#34A853"/>
                                                <Path Data="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" Fill="#FBBC05"/>
                                                <Path Data="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" Fill="#EA4335"/>
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Grid.Column="1" x:Name="TxtLinkGoogle" Text="Vincular Google" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"  />
                                    </Grid>
                                </Button>
                                
                                <Button Command="{x:Bind ViewModel.LinkGitHubCommand}" 
                                        Visibility="{x:Bind ViewModel.CanLinkGitHub, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" 
                                        HorizontalAlignment="Stretch" Padding="8" CornerRadius="6">
                                    <Grid HorizontalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Viewbox Grid.Column="0" Width="16" Height="16" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Path Data="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
                                                  Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                                        </Viewbox>
                                        <TextBlock Grid.Column="1" x:Name="TxtLinkGitHub" Text="Vincular GitHub" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"  />
                                    </Grid>
                                </Button>
                            </StackPanel>
                            <TextBlock x:Name="TxtLinkDesc" Text="Ao vincular, você poderá entrar na sua conta com qualquer um dos provedores associados." FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" TextAlignment="Center"  />
                        </StackPanel>

                        <Border BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Margin="0,4" />

                        <!-- Plano PRO ativo -->
                        <StackPanel x:Name="ProActivePanel" Spacing="16" Visibility="{x:Bind ViewModel.ProPlanVisibility, Mode=OneWay}"
                                    HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE734;" FontSize="24" Foreground="Gold" />
                                <TextBlock x:Name="TxtProActiveTitle" Text="Plano PRO Ativo!" FontWeight="Bold" FontSize="16"  />
                            </StackPanel>
                            <TextBlock x:Name="TxtProActiveDesc" Text="Você tem acesso completo a todos os recursos exclusivos." FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"  />
                            <Button Command="{x:Bind ViewModel.OpenCustomerPortalCommand}"
                                    HorizontalAlignment="Stretch" Padding="0,12" CornerRadius="8" Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE9E9;" FontSize="14" />
                                    <TextBlock x:Name="TxtProManage" Text="Gerenciar ou Cancelar Assinatura" FontWeight="SemiBold" FontSize="13"  />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Plano Pausado -->
                        <StackPanel x:Name="PausedActivePanel" Spacing="16" Visibility="{x:Bind ViewModel.PausedPlanVisibility, Mode=OneWay}"
                                    HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE769;" FontSize="24" Foreground="Orange" />
                                <TextBlock x:Name="TxtPausedActiveTitle" Text="Plano Pausado" FontWeight="Bold" FontSize="16"  />
                            </StackPanel>
                            <TextBlock x:Name="TxtPausedActiveDesc" Text="Sua assinatura está pausada. Retome-a no portal para voltar a ter acesso PRO." FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"  />
                            <Button Command="{x:Bind ViewModel.OpenCustomerPortalCommand}"
                                    HorizontalAlignment="Stretch" Padding="0,12" CornerRadius="8" Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE9E9;" FontSize="14" />
                                    <TextBlock x:Name="TxtPausedManage" Text="Gerenciar Assinatura" FontWeight="SemiBold" FontSize="13"  />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <HyperlinkButton x:Name="BtnLogout" Content="Fazer Logout" Command="{x:Bind ViewModel.LogoutCommand}" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,8,0,0"  />
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- COMPARAÇÃO DE PLANOS (Movido de SettingsPage) -->
            <StackPanel Spacing="16" Margin="0,40,0,40" MaxWidth="1000" HorizontalAlignment="Center">
                <TextBlock x:Name="SettingsSubTitleElement" Text="Assinatura e Conta" Style="{StaticResource SubtitleTextBlockStyle}" HorizontalAlignment="Center"  />
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- COMMUNITY -->
                    <Border Grid.Column="0" CornerRadius="8" Padding="20"
                            BorderThickness="1" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Visibility="{x:Bind ViewModel.InverseProVisibility, Mode=OneWay}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Spacing="10">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Community" Style="{StaticResource SubtitleTextBlockStyle}" />
                                    <TextBlock Text="Open Source · Grátis para sempre"
                                               Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontSize="12" />
                                </StackPanel>
                                <TextBlock Text="O pacote base focado em produtividade extrema, rodando 100% offline sem necessidade de conta ou login."
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" FontSize="12" />

                                <Border BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Margin="0,4" />

                                <StackPanel Spacing="7">
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock TextWrapping="Wrap" FontSize="12"><Run x:Name="SettingsCommF1BElement" FontWeight="SemiBold">Design WinUI 3 Premium:</Run><Run Text=" " /><Run x:Name="SettingsCommF1DElement" >Mica, Glassmorphism e Dark Mode nativo.</Run></TextBlock></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock TextWrapping="Wrap" FontSize="12"><Run x:Name="SettingsCommF2BElement" FontWeight="SemiBold">Always On Top:</Run><Run Text=" " /><Run x:Name="SettingsCommF2DElement" >Fixe qualquer janela acima de todas.</Run></TextBlock></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock TextWrapping="Wrap" FontSize="12"><Run x:Name="SettingsCommF3BElement" FontWeight="SemiBold">Awake (Caffeine):</Run><Run Text=" " /><Run x:Name="SettingsCommF3DElement" >Impede suspensão da tela.</Run></TextBlock></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock TextWrapping="Wrap" FontSize="12"><Run x:Name="SettingsCommF4BElement" FontWeight="SemiBold">Clipboard Avançado:</Run><Run Text=" " /><Run x:Name="SettingsCommF4DElement" >Histórico completo de Ctrl+C.</Run></TextBlock></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock TextWrapping="Wrap" FontSize="12"><Run x:Name="SettingsCommF5BElement" FontWeight="SemiBold">Color Picker e Lupa:</Run><Run Text=" " /><Run x:Name="SettingsCommF5DElement" >Captura HEX/RGB de qualquer pixel.</Run></TextBlock></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock TextWrapping="Wrap" FontSize="12"><Run x:Name="SettingsCommF6BElement" FontWeight="SemiBold">Pesquisa Universal:</Run><Run Text=" " /><Run x:Name="SettingsCommF6DElement" >Spotlight para arquivos e ações.</Run></TextBlock></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock TextWrapping="Wrap" FontSize="12"><Run x:Name="SettingsCommF7BElement" FontWeight="SemiBold">Temporizadores:</Run><Run Text=" " /><Run x:Name="SettingsCommF7DElement" >Múltiplos timers e método Pomodoro.</Run></TextBlock></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock TextWrapping="Wrap" FontSize="12"><Run x:Name="SettingsCommF8BElement" FontWeight="SemiBold">Notas Rápidas:</Run><Run Text=" " /><Run x:Name="SettingsCommF8DElement" >Bloco de anotações sempre à mão.</Run></TextBlock></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock TextWrapping="Wrap" FontSize="12"><Run x:Name="SettingsCommF9BElement" FontWeight="SemiBold">Automações e CLI:</Run><Run Text=" " /><Run x:Name="SettingsCommF9DElement" >Scripts e comandos de terminal.</Run></TextBlock></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock TextWrapping="Wrap" FontSize="12"><Run x:Name="SettingsCommF10BElement" FontWeight="SemiBold">Utilitários de Texto:</Run><Run Text=" " /><Run x:Name="SettingsCommF10DElement" >Modificadores e tradução rápida.</Run></TextBlock></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock x:Name="SettingsCommF11Element" FontSize="12" Text="Suporte da Comunidade (GitHub)"  /></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✗" Foreground="{ThemeResource SystemFillColorCriticalBrush}" FontWeight="Bold" /><TextBlock x:Name="SettingsCommF13Element" Text="Sem Modelos Locais (Llama 3 / Whisper)" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"  /></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✗" Foreground="{ThemeResource SystemFillColorCriticalBrush}" FontWeight="Bold" /><TextBlock x:Name="SettingsCommF14Element" Text="Sem Sincronização em Nuvem" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"  /></StackPanel>
                                </StackPanel>
                            </StackPanel>
                            <!-- Sem botão no Community -->
                        </Grid>
                    </Border>

                    <!-- PRO -->
                    <Border Grid.Column="1" CornerRadius="8" Padding="20"
                            BorderThickness="2" BorderBrush="{ThemeResource AccentFillColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Spacing="10">
                                <StackPanel Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="PRO" Style="{StaticResource SubtitleTextBlockStyle}" />
                                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                            <TextBlock x:Name="SettingsProBadgeElement" Text="Recomendado" FontSize="10" FontWeight="Bold" Foreground="White"  />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock x:Name="SettingsProSubtitleElement" Text="Licença Nuvem · Atualizada automaticamente" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"  />
                                </StackPanel>
                                <TextBlock x:Name="SettingsProDescElement" Text="Voltada para profissionais. Inclui TODAS as funcionalidades Community, mais:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12"  />

                                <Border BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Margin="0,4" />

                                <StackPanel Spacing="7">
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock x:Name="SettingsProF1Element" Text="Todas as funcionalidades Community" FontWeight="SemiBold" FontSize="12"  /></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock TextWrapping="Wrap" FontSize="12"><Run x:Name="SettingsProF2BElement" FontWeight="SemiBold">Sincronização em Nuvem (Firebase):</Run><Run Text=" " /><Run x:Name="SettingsProF2DElement" >Login seguro e gestão da chave PRO.</Run></TextBlock></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock TextWrapping="Wrap" FontSize="12"><Run x:Name="SettingsProF3BElement" FontWeight="SemiBold">IA Autônoma (Semantic Kernel):</Run><Run Text=" " /><Run x:Name="SettingsProF3DElement" >Agente central alimentado pela Microsoft.</Run></TextBlock></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock TextWrapping="Wrap" FontSize="12"><Run x:Name="SettingsProF4BElement" FontWeight="SemiBold">LLM 100% Local (Ollama):</Run><Run Text=" " /><Run x:Name="SettingsProF4DElement" >Processa Llama 3 no seu hardware. Privacidade absoluta.</Run></TextBlock></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock TextWrapping="Wrap" FontSize="12"><Run x:Name="SettingsProF5BElement" FontWeight="SemiBold">Reconhecimento de Voz (Whisper):</Run><Run Text=" " /><Run x:Name="SettingsProF5DElement" >Transcreva áudio offline com redes neurais.</Run></TextBlock></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock TextWrapping="Wrap" FontSize="12"><Run x:Name="SettingsProF6BElement" FontWeight="SemiBold">Respostas em Streaming:</Run><Run Text=" " /><Run x:Name="SettingsProF6DElement" >A IA digita instantaneamente enquanto pensa.</Run></TextBlock></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock TextWrapping="Wrap" FontSize="12"><Run x:Name="SettingsProF7BElement" FontWeight="SemiBold">Visão Computacional Local:</Run><Run Text=" " /><Run x:Name="SettingsProF7DElement" >Anexe prints e imagens para a IA analisar.</Run></TextBlock></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock TextWrapping="Wrap" FontSize="12"><Run x:Name="SettingsProF8BElement" FontWeight="SemiBold">Biblioteca de Prompts:</Run><Run Text=" " /><Run x:Name="SettingsProF8DElement" >Salve e reutilize prompts em um clique.</Run></TextBlock></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock TextWrapping="Wrap" FontSize="12"><Run x:Name="SettingsProF9BElement" FontWeight="SemiBold">[EM BREVE] Marketplace de Plugins:</Run><Run Text=" " /><Run x:Name="SettingsProF9DElement" >Loja embutida com módulos nativos em C#.</Run></TextBlock></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock x:Name="SettingsProF10Element" FontSize="12" Text="Atualizações Prioritárias via Store"  /></StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="✔" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="Bold" /><TextBlock x:Name="SettingsProF11Element" FontSize="12" Text="Suporte Dedicado via E-mail"  /></StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- PRO Upgrade Buttons -->
                            <StackPanel Grid.Row="1" Margin="0,16,0,0" Spacing="8"
                                        Visibility="{x:Bind ViewModel.InverseProVisibility, Mode=OneWay}">

                                <!-- Botão Mensal — Accent principal -->
                                <Button HorizontalAlignment="Stretch" Padding="0" CornerRadius="10"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Command="{x:Bind ViewModel.UpgradeMonthlyCommand}">
                                    <Grid Padding="16,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE735;" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock x:Name="AuthProMonthlyTitleElement" Text="Assinar PRO" FontWeight="Bold" FontSize="16"  />
                                            <TextBlock x:Name="AuthProMonthlySubtitleElement" Text="R$ 39,90 BRL / mês · Cancele quando quiser" FontSize="13" Opacity="0.85"  />
                                        </StackPanel>
                                        <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="13" VerticalAlignment="Center" Margin="12,0,0,0" />
                                    </Grid>
                                </Button>

                                <!-- Botão Anual com badge flutuante -->
                                <Grid>
                                    <Button HorizontalAlignment="Stretch" Padding="0" CornerRadius="10"
                                            Command="{x:Bind ViewModel.UpgradeYearlyCommand}">
                                        <Grid Padding="16,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0" Glyph="&#xE787;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"
                                                      Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                <TextBlock x:Name="AuthProYearlyTitleElement" Text="Plano Anual" FontWeight="SemiBold" FontSize="15"  />
                                                <TextBlock x:Name="AuthProYearlySubtitleElement" Text="R$ 429,90 BRL / ano" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"  />
                                            </StackPanel>
                                            <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </Grid>
                                    </Button>
                                    <!-- Badge de desconto flutuante -->
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,-12,-12,0"
                                            CornerRadius="10" Padding="12,6"
                                            BorderThickness="1" BorderBrush="#40FFFFFF">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FFD700" Offset="0.0" />
                                                <GradientStop Color="#FF8C00" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock x:Name="AuthProYearlyBadgeElement" Text="DESCONTO DE 10%" FontSize="11" FontWeight="Black" Foreground="White" CharacterSpacing="20" />
                                    </Border>
                                </Grid>

                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
