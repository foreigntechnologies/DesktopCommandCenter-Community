<Page
    x:Class="DesktopCommandCenter.UI.Views.AuthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="24">
        <ScrollViewer>
            <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                        MaxWidth="480" Margin="0,40,0,40">

                <!-- Header -->
                <StackPanel Spacing="8" HorizontalAlignment="Center" Margin="0,0,0,40">
                    <FontIcon Glyph="&#xE7BF;" FontSize="48"
                              Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="Licenciamento &amp; Nuvem"
                               Style="{StaticResource TitleTextBlockStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="O DCC funciona 100% offline e gratuito. Faça login apenas para desbloquear os recursos PRO Enterprise."
                               TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" />
                </StackPanel>

                <!-- Mensagens globais (Loading / Erro / Sucesso) -->
                <StackPanel Spacing="12" Margin="0,0,0,20">
                    <StackPanel Spacing="12" HorizontalAlignment="Center"
                                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}">
                        <ProgressRing IsActive="True" Width="32" Height="32" HorizontalAlignment="Center" />
                        <TextBlock Text="Processando requisição..."
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="12" />
                    </StackPanel>

                    <Border CornerRadius="8" Padding="12,10"
                            Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                            Visibility="{x:Bind ViewModel.HasError, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE783;" FontSize="16"
                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       TextWrapping="Wrap" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Mensagem de Sucesso Genérica -->
                    <Border CornerRadius="8" Padding="12,10"
                            Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                            Visibility="{x:Bind ViewModel.HasSuccess, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE73E;" FontSize="16"
                                      Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                       Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                       TextWrapping="Wrap" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ══ PAINEL NÃO LOGADO ══ -->
                <StackPanel Spacing="16" Visibility="{x:Bind ViewModel.IsNotLoggedIn, Mode=OneWay}">

                    <!-- Google -->
                    <Button Command="{x:Bind ViewModel.LoginWithGoogleCommand}"
                            IsEnabled="{x:Bind ViewModel.IsNotLoading, Mode=OneWay}"
                            HorizontalAlignment="Stretch" Padding="14,12"
                            CornerRadius="8">
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                            <!-- Google logo SVG -->
                            <Viewbox Width="20" Height="20" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" Fill="#4285F4"/>
                                    <Path Data="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" Fill="#34A853"/>
                                    <Path Data="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" Fill="#FBBC05"/>
                                    <Path Data="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" Fill="#EA4335"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Continuar com o Google" VerticalAlignment="Center"
                                       FontWeight="SemiBold" FontSize="14" />
                        </StackPanel>
                    </Button>

                    <!-- GitHub -->
                    <Button Command="{x:Bind ViewModel.LoginWithGitHubCommand}"
                            IsEnabled="{x:Bind ViewModel.IsNotLoading, Mode=OneWay}"
                            HorizontalAlignment="Stretch" Padding="14,12"
                            CornerRadius="8">
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                            <Viewbox Width="20" Height="20" VerticalAlignment="Center">
                                <Path Data="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
                                      Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                            </Viewbox>
                            <TextBlock Text="Continuar com o GitHub" VerticalAlignment="Center"
                                       FontWeight="SemiBold" FontSize="14" />
                        </StackPanel>
                    </Button>

                    <!-- Botões de login movidos para cima para manter os erros abaixo -->

                    <!-- Nota de privacidade -->
                    <TextBlock FontSize="11" TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Margin="0,8,0,0">
                        <Run>Ao continuar, você aceita os </Run>
                        <Hyperlink NavigateUri="https://foreigntechnologies.com.br/legal/terms">Termos de Uso</Hyperlink>
                        <Run> e a </Run>
                        <Hyperlink NavigateUri="https://foreigntechnologies.com.br/legal/privacy">Política de Privacidade</Hyperlink>
                        <Run>.</Run>
                    </TextBlock>
                </StackPanel>

                <!-- ══ PAINEL LOGADO ══ -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="12" Padding="28"
                        Visibility="{x:Bind ViewModel.IsLoggedIn, Mode=OneWay}">
                    <StackPanel Spacing="20">

                        <!-- Info da conta -->
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE77B;" FontSize="40"
                                      Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                      HorizontalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.UserEmail, Mode=OneWay}"
                                       FontWeight="SemiBold" HorizontalAlignment="Center" FontSize="15" />
                            <TextBlock Text="{x:Bind ViewModel.PlanDisplayText, Mode=OneWay}"
                                       Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                       HorizontalAlignment="Center" FontSize="12" />
                        </StackPanel>

                        <Border BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" />

                        <!-- Vinculação de Contas -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="Vincular contas adicionais:" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                <Button Command="{x:Bind ViewModel.LinkGoogleCommand}" Content="Vincular Google" Padding="12,6" ToolTipService.ToolTip="Fazer login também via Google" />
                                <Button Command="{x:Bind ViewModel.LinkGitHubCommand}" Content="Vincular GitHub" Padding="12,6" ToolTipService.ToolTip="Fazer login também via GitHub" />
                            </StackPanel>
                            <TextBlock Text="Ao vincular, você poderá entrar na sua conta com qualquer um dos provedores associados."
                                       FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       TextWrapping="Wrap" TextAlignment="Center" />
                        </StackPanel>

                        <Border BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" />

                        <!-- Ações PRO / Free -->
                        <StackPanel Spacing="10" Visibility="{x:Bind ViewModel.IsFreePlan, Mode=OneWay}">
                            <TextBlock Text="Assine o PRO Enterprise para desbloquear:"
                                       FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <StackPanel Spacing="4">
                                <TextBlock Text="✔  IA Autônoma com Semantic Kernel + Ollama" FontSize="12" />
                                <TextBlock Text="✔  Reconhecimento de Voz Offline (Whisper)" FontSize="12" />
                                <TextBlock Text="✔  Biblioteca de Prompts e Automações" FontSize="12" />
                                <TextBlock Text="✔  Marketplace de Plugins (em breve)" FontSize="12" />
                            </StackPanel>
                            <Button Command="{x:Bind ViewModel.UpgradeMonthlyCommand}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    HorizontalAlignment="Stretch" Padding="12,10" Margin="0,8,0,0">
                                <TextBlock Text="Assinar PRO — R$ 39,90/mês" FontWeight="SemiBold" />
                            </Button>
                            <Button Command="{x:Bind ViewModel.UpgradeYearlyCommand}"
                                    HorizontalAlignment="Stretch" Padding="12,10">
                                <TextBlock Text="Anual — R$ 429,90/ano · Economize 10%" />
                            </Button>
                        </StackPanel>

                        <!-- Plano PRO ativo -->
                        <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.IsProPlan, Mode=OneWay}"
                                    HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE734;" FontSize="20" Foreground="Gold" />
                                <TextBlock Text="Plano PRO Enterprise Ativo!" FontWeight="Bold" FontSize="15" />
                            </StackPanel>
                            <TextBlock Text="Você tem acesso completo a todos os recursos." FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <Button Command="{x:Bind ViewModel.OpenCustomerPortalCommand}"
                                    HorizontalAlignment="Stretch" Padding="12,10">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE9E9;" FontSize="13" />
                                    <TextBlock Text="Gerenciar / Cancelar Assinatura" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <HyperlinkButton Content="Sair da Conta"
                                         Command="{x:Bind ViewModel.LogoutCommand}"
                                         HorizontalAlignment="Center"
                                         Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
