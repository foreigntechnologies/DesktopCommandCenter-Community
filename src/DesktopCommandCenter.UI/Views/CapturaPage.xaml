<Page NavigationCacheMode="Required"
    x:Class="DesktopCommandCenter.UI.Views.CapturaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="CapturePageTitleElement" Text="Captura de Tela" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16" />

        <Grid Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="32" HorizontalAlignment="Left" VerticalAlignment="Top" MaxWidth="500">
            <StackPanel Spacing="16">
                <TextBlock x:Name="CaptureSubTitleElement" Text="Estúdio de Captura" Style="{StaticResource SubtitleTextBlockStyle}"  />
                <TextBlock x:Name="CaptureDescElement" Text="Selecione abaixo para iniciar a ferramenta de captura de tela inteligente do Windows e salvar imagens diretamente no seu Clipboard." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"  />

                <Button x:Name="CaptureBtnStartElement" Content="📸 Nova Captura" Command="{x:Bind ViewModel.CaptureScreenCommand}" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" MinHeight="60" FontSize="18" Margin="0,16,0,0"  />
            </StackPanel>
        </Grid>
    </Grid>
</Page>

