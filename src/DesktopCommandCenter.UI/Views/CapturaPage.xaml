<Page
    x:Class="DesktopCommandCenter.UI.Views.CapturaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:DesktopCommandCenter.UI.Helpers"
    Background="Transparent">
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock helpers:Translate.Key="Capture_PageTitle" Text="Captura de Tela" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16"/>

        <Grid Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="32" HorizontalAlignment="Left" VerticalAlignment="Top" MaxWidth="500">
            <StackPanel Spacing="16">
                <TextBlock helpers:Translate.Key="Capture_SubTitle" Text="Estúdio de Captura" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock helpers:Translate.Key="Capture_Desc" Text="Selecione abaixo para iniciar a ferramenta de captura de tela inteligente do Windows e salvar imagens diretamente no seu Clipboard." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                <Button helpers:Translate.Key="Capture_BtnStart" Content="📸 Nova Captura" Command="{x:Bind ViewModel.CaptureScreenCommand}" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" MinHeight="60" FontSize="18" Margin="0,16,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
