<Page
    x:Class="DesktopCommandCenter.UI.Views.TemporizadorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Temporizador (Pomodoro)" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16"/>

        <Grid Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="32" HorizontalAlignment="Left" VerticalAlignment="Top" MaxWidth="500">
            <StackPanel Spacing="24" HorizontalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.TimeDisplay, Mode=OneWay}" FontSize="72" FontWeight="Bold" FontFamily="Consolas" HorizontalAlignment="Center" />
                
                <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                    <NumberBox Value="{x:Bind ViewModel.InputMinutes, Mode=TwoWay}" Header="Minutos" Minimum="1" Maximum="120" Width="100"/>
                    <Button Content="Resetar" Command="{x:Bind ViewModel.ResetTimerCommand}" VerticalAlignment="Bottom" />
                </StackPanel>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Content="Iniciar" Command="{x:Bind ViewModel.StartTimerCommand}" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" IsEnabled="{x:Bind ViewModel.IsNotRunning, Mode=OneWay}" />
                    <Button Grid.Column="1" Content="Pausar" Command="{x:Bind ViewModel.StopTimerCommand}" HorizontalAlignment="Stretch" IsEnabled="{x:Bind ViewModel.IsRunning, Mode=OneWay}" />
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
