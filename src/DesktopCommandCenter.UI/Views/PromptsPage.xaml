<Page NavigationCacheMode="Required"
    x:Class="DesktopCommandCenter.UI.Views.PromptsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:DesktopCommandCenter.UI.ViewModels"
    xmlns:domain="using:DesktopCommandCenter.Domain.Entities"
    x:Name="RootPage"
    Background="Transparent">
    
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptsPageTitleElement" Text="Biblioteca de Prompts" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16" />

        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- COLUNA ESQUERDA: LISTAGEM DE PROMPTS -->
            <Grid Grid.Column="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
                    <GridView ItemsSource="{x:Bind ViewModel.Prompts, Mode=OneWay}" SelectionMode="None">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="domain:Prompt">
                                <Grid Width="280" Height="220" Padding="16" Margin="0,0,12,12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Text="{x:Bind Title}" FontWeight="Bold" FontSize="16" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Row="1" Text="{x:Bind Category}" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" FontSize="12" Margin="0,4,0,8"/>
                                    
                                    <TextBlock Grid.Row="2" Text="{x:Bind Content}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    
                                    <!-- A├āŌĆĪ├āŌĆóES R├ā┬üPIDAS -->
                                    <Grid Grid.Row="3" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Button x:Name="PromptsBtnCopyElement" ToolTipService.ToolTip="{Binding Converter={StaticResource TranslateConverter}, ConverterParameter='Prompts_BtnCopy'}" Content="Copiar" HorizontalAlignment="Stretch" Margin="0,0,8,0" Command="{Binding ElementName=RootPage, Path=ViewModel.CopyPromptCommand}" CommandParameter="{x:Bind}" />
                                        
                                        <Button Grid.Column="1" Padding="8,4" Margin="0,0,4,0"
                                                Command="{Binding ElementName=RootPage, Path=ViewModel.SelectPromptForEditCommand}"
                                                CommandParameter="{x:Bind}">
                                            <ToolTipService.ToolTip>
                                                <ToolTip x:Name="PromptsToolTipEditElement" ToolTipService.ToolTip="{Binding Converter={StaticResource TranslateConverter}, ConverterParameter='Prompts_ToolTipEdit'}" Content="Editar"  />
                                            </ToolTipService.ToolTip>
                                            <SymbolIcon Symbol="Edit"/>
                                        </Button>
                                        
                                        <Button Grid.Column="2" Padding="8,4"
                                                Command="{Binding ElementName=RootPage, Path=ViewModel.DeletePromptCommand}"
                                                CommandParameter="{x:Bind}"
                                                Foreground="Red">
                                            <ToolTipService.ToolTip>
                                                <ToolTip x:Name="PromptsToolTipDeleteElement" ToolTipService.ToolTip="{Binding Converter={StaticResource TranslateConverter}, ConverterParameter='Prompts_ToolTipDelete'}" Content="Excluir"  />
                                            </ToolTipService.ToolTip>
                                            <SymbolIcon Symbol="Delete"/>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </ScrollViewer>
                
                <!-- Mensagem quando estiver vazio -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" 
                            Visibility="{x:Bind ViewModel.EmptyMessageVisibility, Mode=OneWay}">
                    <SymbolIcon Symbol="OutlineStar" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="PromptsEmptyTitleElement" Text="Nenhum prompt salvo ainda." Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock x:Name="PromptsEmptyDescElement" Text="Crie um novo prompt usando o formulßrio ├ direita." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- COLUNA DIREITA: FORMUL├üRIO DE CADASTRO/EDIŪ├āO -->
            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20" VerticalAlignment="Top">
                <StackPanel Spacing="16">
                    <TextBlock Text="{x:Bind ViewModel.FormTitle, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>

                    <TextBox x:Name="PromptsInputTitleElement" Header="TĒtulo" PlaceholderText="Ex: Revisar C¾digo" Text="{x:Bind ViewModel.EditTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox x:Name="PromptsInputCatElement" Header="Categoria" PlaceholderText="Ex: ProgramańŃo" Text="{x:Bind ViewModel.EditCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox x:Name="PromptsInputContentElement" Header="Conte·do do Prompt" PlaceholderText="Por favor, revise o c¾digo abaixo..." Text="{x:Bind ViewModel.EditContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="150" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" />

                    <Grid ColumnSpacing="12" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button x:Name="PromptsBtnSaveElement" Content="Salvar" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.SavePromptCommand}" />
                                
                        <Button x:Name="PromptsBtnCancelElement" Grid.Column="1" Content="Cancelar" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.ClearFormCommand}" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>


