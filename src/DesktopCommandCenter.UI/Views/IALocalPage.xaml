<Page
    x:Class="DesktopCommandCenter.UI.Views.IALocalPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:DesktopCommandCenter.UI.ViewModels"
    Background="Transparent">
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,0,0,16">
            <TextBlock Text="ChatFT" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" VerticalAlignment="Bottom" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:ChatMessage">
                    <Grid Margin="0,8">
                        <Border CornerRadius="8" Padding="16" MaxWidth="600" HorizontalAlignment="Left" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <StackPanel>
                                <TextBlock Text="{x:Bind Role}" FontWeight="Bold" Margin="0,0,0,4" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" />
                                <Image Source="{x:Bind ImagePath}" MaxWidth="300" MaxHeight="300" HorizontalAlignment="Left" Margin="0,0,0,8" Visibility="{x:Bind HasImage}" />
                                <TextBlock Text="{x:Bind Content}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border Grid.Row="2" Margin="0,16,0,0" Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="20" Padding="8,4,8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Bottom" Margin="0,0,4,4">
                    <Button Command="{x:Bind ViewModel.AttachImageCommand}" Background="Transparent" BorderThickness="0" CornerRadius="16" Width="36" Height="36" Padding="0">
                        <ToolTipService.ToolTip>
                            <ToolTip x:Name="TooltipAttachImage" Content="Anexar Imagem" />
                        </ToolTipService.ToolTip>
                        <FontIcon Glyph="&#xEB9F;" FontSize="16"/>
                    </Button>
                    <Button Command="{x:Bind ViewModel.AttachAudioCommand}" Background="Transparent" BorderThickness="0" CornerRadius="16" Width="36" Height="36" Padding="0">
                        <ToolTipService.ToolTip>
                            <ToolTip x:Name="TooltipAttachAudio" Content="Transcrever Áudio" />
                        </ToolTipService.ToolTip>
                        <FontIcon Glyph="&#xE8D6;" FontSize="16" />
                    </Button>
                    <Button Command="{x:Bind ViewModel.ToggleRecordingCommand}" Background="Transparent" BorderThickness="0" CornerRadius="16" Width="36" Height="36" Padding="0" Foreground="{ThemeResource SystemControlForegroundAccentBrush}">
                        <ToolTipService.ToolTip>
                            <ToolTip x:Name="TooltipMic" Content="Falar no Microfone" />
                        </ToolTipService.ToolTip>
                        <FontIcon Glyph="&#xE720;" FontSize="16"/>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.AttachedImagePath, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" Margin="4,0,0,2" />
                    <TextBox x:Name="TxtPromptInput" Text="{x:Bind ViewModel.CurrentPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             PlaceholderText="Escreva seu prompt aqui, fale ao microfone ou anexe uma imagem..." 
                             AcceptsReturn="True" MaxHeight="120" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" />
                </StackPanel>
                         
                <Button x:Name="BtnSend" Grid.Column="2" Command="{x:Bind ViewModel.SendMessageCommand}" 
                        Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Bottom" Margin="4,0,0,4" CornerRadius="16" Width="36" Height="36" Padding="0">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Name="TooltipSend" Content="Enviar" />
                    </ToolTipService.ToolTip>
                    <FontIcon Glyph="&#xE72A;" FontSize="14" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>
