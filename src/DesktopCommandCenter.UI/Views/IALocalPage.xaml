<Page
    x:Class="DesktopCommandCenter.UI.Views.IALocalPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:DesktopCommandCenter.UI.ViewModels"
    Background="Transparent">
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,0,0,16">
            <TextBlock Text="ChatFT" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" VerticalAlignment="Bottom" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:ChatMessage">
                    <Grid Margin="0,8">
                        <Border CornerRadius="8" Padding="16" MaxWidth="600" HorizontalAlignment="Left" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <StackPanel>
                                <TextBlock Text="{x:Bind Role}" FontWeight="Bold" Margin="0,0,0,4" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" />
                                <Image Source="{x:Bind ImagePath}" MaxWidth="300" MaxHeight="300" HorizontalAlignment="Left" Margin="0,0,0,8" Visibility="{x:Bind HasImage}" />
                                <TextBlock Text="{x:Bind Content}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="2" Margin="0,16,0,0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Bottom" Margin="0,0,0,4">
                <Button Command="{x:Bind ViewModel.AttachImageCommand}" Background="Transparent" BorderThickness="0">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Name="TooltipAttachImage" Content="Anexar Imagem" />
                    </ToolTipService.ToolTip>
                    <FontIcon Glyph="&#xEB9F;" />
                </Button>
                <Button Command="{x:Bind ViewModel.AttachAudioCommand}" Background="Transparent" BorderThickness="0">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Name="TooltipAttachAudio" Content="Transcrever Áudio" />
                    </ToolTipService.ToolTip>
                    <FontIcon Glyph="&#xE8D6;" />
                </Button>
                <Button Command="{x:Bind ViewModel.ToggleRecordingCommand}" Background="Transparent" BorderThickness="0" Foreground="{ThemeResource SystemControlForegroundAccentBrush}">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Name="TooltipMic" Content="Falar no Microfone" />
                    </ToolTipService.ToolTip>
                    <FontIcon Glyph="&#xE720;" />
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <TextBlock Text="{x:Bind ViewModel.AttachedImagePath, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" Margin="0,0,0,4" />
                <TextBox x:Name="TxtPromptInput" Text="{x:Bind ViewModel.CurrentPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         PlaceholderText="Escreva seu prompt aqui, fale ao microfone ou anexe uma imagem..." 
                         AcceptsReturn="True" MaxHeight="100"/>
            </StackPanel>
                     
            <Button x:Name="BtnSend" Grid.Column="2" Content="Enviar" Command="{x:Bind ViewModel.SendMessageCommand}" 
                    Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Bottom" MinWidth="100"/>
        </Grid>
    </Grid>
</Page>
