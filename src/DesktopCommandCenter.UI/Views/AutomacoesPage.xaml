<Page
    x:Class="DesktopCommandCenter.UI.Views.AutomacoesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:DesktopCommandCenter.UI.ViewModels"
    xmlns:helpers="using:DesktopCommandCenter.UI.Helpers"
    x:Name="Root"
    Background="Transparent">
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,16">
            <TextBlock helpers:Translate.Key="Auto_PageTitle" Text="Regras de Automação" Style="{StaticResource TitleTextBlockStyle}" />
            <Button helpers:Translate.Key="Auto_BtnNewRule" Content="+ Nova Regra" Click="NovaRegraButton_Click" HorizontalAlignment="Right" Style="{StaticResource AccentButtonStyle}" />
        </Grid>

        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Regras, Mode=OneWay}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:AutomacaoRegra">
                    <Grid Padding="16" Margin="0,4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel>
                            <TextBlock helpers:Translate.Key="Auto_TriggerLabel" Text="Se isso acontecer (Gatilho):" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind GatilhoCompleto, Mode=OneWay}" FontWeight="Bold" FontSize="16" />
                        </StackPanel>

                        <FontIcon Grid.Column="1" Glyph="&#xE72A;" Margin="24,0" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" />

                        <StackPanel Grid.Column="2">
                            <TextBlock helpers:Translate.Key="Auto_ActionLabel" Text="Então faça isso (Ação):" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind AcaoCompleta, Mode=OneWay}" FontWeight="Bold" FontSize="16" />
                        </StackPanel>

                        <ToggleSwitch Grid.Column="3" IsOn="{x:Bind IsAtivo, Mode=TwoWay}" Margin="24,0,0,0" VerticalAlignment="Center" AutomationProperties.Name="Ativar ou desativar regra de automação" />

                        <Button Grid.Column="4" Command="{Binding ElementName=Root, Path=ViewModel.RemoveRegraCommand}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Margin="16,0,0,0">
                            <ToolTipService.ToolTip>
                                <ToolTip helpers:Translate.Key="Auto_BtnRemove" Content="Remover regra" />
                            </ToolTipService.ToolTip>
                            <FontIcon Glyph="&#xE74D;" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ContentDialog x:Name="NovaRegraDialog" helpers:Translate.Key="Auto_DialogTitle" Title="Criar Nova Regra" PrimaryButtonText="Salvar" CloseButtonText="Cancelar" PrimaryButtonClick="NovaRegraDialog_PrimaryButtonClick">
            <StackPanel Spacing="16" Width="400">
                <ComboBox x:Name="TriggersCombo" helpers:Translate.Key="Auto_ComboTrigger" Header="Gatilho (Se isso acontecer)" ItemsSource="{x:Bind ViewModel.AvailableTriggers}" HorizontalAlignment="Stretch" SelectionChanged="TriggersCombo_SelectionChanged" />
                <TextBox x:Name="TriggerParamTextBox" HorizontalAlignment="Stretch" Visibility="Collapsed" />
                
                <ComboBox x:Name="ActionsCombo" helpers:Translate.Key="Auto_ComboAction" Header="Ação (Faça isso)" ItemsSource="{x:Bind ViewModel.AvailableActions}" HorizontalAlignment="Stretch" SelectionChanged="ActionsCombo_SelectionChanged" />
                <ComboBox x:Name="LanguageCombo" helpers:Translate.Key="Auto_ComboLang" Header="Linguagem do Script" ItemsSource="{x:Bind ViewModel.AvailableLanguages}" HorizontalAlignment="Stretch" Visibility="Collapsed" />
                <TextBox x:Name="ActionParamTextBox" HorizontalAlignment="Stretch" Visibility="Collapsed" />
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>
