<Page
    x:Class="DesktopCommandCenter.UI.Views.AutomacoesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:DesktopCommandCenter.UI.ViewModels"
    x:Name="Root"
    Background="Transparent">
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,16">
            <TextBlock x:Name="AutoPageTitleElement" Text="Regras de AutomaÃ§Ã£o" Style="{StaticResource TitleTextBlockStyle}"  />
            <Button x:Name="AutoBtnNewRuleElement" Content="+ Nova Regra" Click="NovaRegraButton_Click" HorizontalAlignment="Right" Style="{StaticResource AccentButtonStyle}"  />
        </Grid>

        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Regras, Mode=OneWay}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:AutomacaoRegra">
                    <Grid Padding="16" Margin="0,4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel>
                            <TextBlock x:Name="AutoTriggerLabelElement" Text="{Binding Converter={StaticResource TranslateConverter}, ConverterParameter='Automations_ListTrigger'}"  FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{Binding GatilhoCompleto, Mode=OneWay}" FontWeight="Bold" FontSize="16" />
                        </StackPanel>

                        <FontIcon Grid.Column="1" Glyph="&#xE72A;" Margin="24,0" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" />

                        <StackPanel Grid.Column="2">
                            <TextBlock x:Name="AutoActionLabelElement" Text="{Binding Converter={StaticResource TranslateConverter}, ConverterParameter='Automations_ListAction'}"  FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{Binding AcaoCompleta, Mode=OneWay}" FontWeight="Bold" FontSize="16" />
                        </StackPanel>

                        <ToggleSwitch Grid.Column="3" IsOn="{Binding IsAtivo, Mode=TwoWay}" Margin="24,0,0,0" VerticalAlignment="Center" AutomationProperties.Name="Ativar ou desativar regra de automaÃ§Ã£o" />

                        <Button Grid.Column="4" Command="{Binding ElementName=Root, Path=ViewModel.RemoveRegraCommand}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Margin="16,0,0,0">
                            <ToolTipService.ToolTip>
                                <ToolTip Content="{Binding Converter={StaticResource TranslateConverter}, ConverterParameter='Automations_ListRemove'}"  />
                            </ToolTipService.ToolTip>
                            <FontIcon Glyph="&#xE74D;" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ContentDialog x:Name="NovaRegraDialog" Title="Criar Nova Regra" PrimaryButtonText="Salvar" CloseButtonText="Cancelar" PrimaryButtonClick="NovaRegraDialog_PrimaryButtonClick">
            <StackPanel Spacing="16" Width="400">
                <ComboBox x:Name="TriggersCombo" Header="Gatilho (Se isso acontecer)" ItemsSource="{x:Bind ViewModel.AvailableTriggers}" HorizontalAlignment="Stretch" SelectionChanged="TriggersCombo_SelectionChanged"  />
                <TextBox x:Name="TriggerParamTextBox" HorizontalAlignment="Stretch" Visibility="Collapsed" />
                
                <ComboBox x:Name="ActionsCombo" Header="AÃ§Ã£o (FaÃ§a isso)" ItemsSource="{x:Bind ViewModel.AvailableActions}" HorizontalAlignment="Stretch" SelectionChanged="ActionsCombo_SelectionChanged"  />
                <ComboBox x:Name="LanguageCombo" Header="Linguagem do Script" ItemsSource="{x:Bind ViewModel.AvailableLanguages}" HorizontalAlignment="Stretch" Visibility="Collapsed"  />
                <TextBox x:Name="ActionParamTextBox" HorizontalAlignment="Stretch" Visibility="Collapsed" />
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>


