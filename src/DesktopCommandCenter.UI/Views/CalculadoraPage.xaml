<Page
    x:Class="DesktopCommandCenter.UI.Views.CalculadoraPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:DesktopCommandCenter.UI.ViewModels"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Calculadora" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16"/>

        <TabView x:Name="CalculatorTabs" Grid.Row="1" IsAddTabButtonVisible="False" TabWidthMode="SizeToContent" SelectionChanged="CalculatorTabs_SelectionChanged">
            <TabView.TabItems>
                
                <!-- Modo Padrão (FREE) -->
                <TabViewItem Header="Padrão">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="Calculator" />
                    </TabViewItem.IconSource>
                    <Grid Padding="24" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Width="480" MaxWidth="500" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Visor Superior (Expressão) -->
                        <TextBlock Text="{x:Bind ViewModel.ExpressionDisplay, Mode=OneWay}" 
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                   FontSize="16" HorizontalAlignment="Right" Margin="0,0,8,4"/>
                        
                        <!-- Visor Principal (Resultado/Entrada) -->
                        <TextBox Grid.Row="1" Text="{x:Bind ViewModel.CurrentEntry, Mode=OneWay}" 
                                 FontSize="48" FontWeight="SemiBold" TextAlignment="Right" 
                                 IsReadOnly="True" BorderThickness="0" Background="Transparent" Margin="0,0,0,16"/>

                        <!-- Teclado Numérico Padrão -->
                        <Grid Grid.Row="2" ColumnSpacing="8" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Button Content="%" Command="{x:Bind ViewModel.CalculatePercentCommand}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" />
                            <Button Grid.Column="1" Content="CE" Command="{x:Bind ViewModel.ClearEntryCommand}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" />
                            <Button Grid.Column="2" Content="C" Command="{x:Bind ViewModel.ClearAllCommand}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" />
                            <Button Grid.Column="3" Content="⌫" Command="{x:Bind ViewModel.BackspaceCommand}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" />

                            <Button Grid.Row="1" Content="7" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="7" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="1" Grid.Column="1" Content="8" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="1" Grid.Column="2" Content="9" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="9" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="1" Grid.Column="3" Content="÷" Command="{x:Bind ViewModel.OperatorCommand}" CommandParameter="/" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" />

                            <Button Grid.Row="2" Content="4" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="2" Grid.Column="1" Content="5" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="2" Grid.Column="2" Content="6" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="2" Grid.Column="3" Content="×" Command="{x:Bind ViewModel.OperatorCommand}" CommandParameter="*" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" />

                            <Button Grid.Row="3" Content="1" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="3" Grid.Column="1" Content="2" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="3" Grid.Column="2" Content="3" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="3" Grid.Column="3" Content="-" Command="{x:Bind ViewModel.OperatorCommand}" CommandParameter="-" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" />

                            <Button Grid.Row="4" Content="+/-" Command="{x:Bind ViewModel.NegateCommand}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" />
                            <Button Grid.Row="4" Grid.Column="1" Content="0" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="4" Grid.Column="2" Content="," Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="," HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" />
                            <Button Grid.Row="4" Grid.Column="3" Content="+" Command="{x:Bind ViewModel.OperatorCommand}" CommandParameter="+" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" />

                            <Button Grid.Row="5" Grid.ColumnSpan="4" Content="=" Command="{x:Bind ViewModel.EvaluateCommand}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" Background="{ThemeResource AccentFillColorDefaultBrush}" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                        </Grid>
                    </Grid>
                </TabViewItem>

                <!-- Modo Científico (FREE) -->
                <TabViewItem Header="Científica">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="Help" />
                    </TabViewItem.IconSource>
                    <Grid Padding="24" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Width="650" MaxWidth="700" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Calculadora Científica Avançada" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.ExpressionDisplay, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="16" HorizontalAlignment="Right" Margin="0,0,8,4"/>
                        <TextBox Grid.Row="2" Text="{x:Bind ViewModel.CurrentEntry, Mode=OneWay}" FontSize="36" FontWeight="SemiBold" TextAlignment="Right" IsReadOnly="True" BorderThickness="0" Background="Transparent" Margin="0,0,0,16"/>
                        
                        <Grid Grid.Row="3" ColumnSpacing="8" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Linha 0 (Parênteses) -->
                            <Button Content="(" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="(" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" Grid.ColumnSpan="3" />
                            <Button Grid.Column="3" Content=")" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter=")" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" Grid.ColumnSpan="3" />

                            <!-- Linha 1 -->
                            <Button Grid.Row="1" Content="sin" Command="{x:Bind ViewModel.ScientificFunctionCommand}" CommandParameter="sin" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />
                            <Button Grid.Row="1" Grid.Column="1" Content="cos" Command="{x:Bind ViewModel.ScientificFunctionCommand}" CommandParameter="cos" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />
                            <Button Grid.Row="1" Grid.Column="2" Content="CE" Command="{x:Bind ViewModel.ClearEntryCommand}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />
                            <Button Grid.Row="1" Grid.Column="3" Content="C" Command="{x:Bind ViewModel.ClearAllCommand}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />
                            <Button Grid.Row="1" Grid.Column="4" Content="⌫" Command="{x:Bind ViewModel.BackspaceCommand}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />
                            <Button Grid.Row="1" Grid.Column="5" Content="÷" Command="{x:Bind ViewModel.OperatorCommand}" CommandParameter="/" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />

                            <!-- Linha 2 -->
                            <Button Grid.Row="2" Content="tan" Command="{x:Bind ViewModel.ScientificFunctionCommand}" CommandParameter="tan" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />
                            <Button Grid.Row="2" Grid.Column="1" Content="√" Command="{x:Bind ViewModel.ScientificFunctionCommand}" CommandParameter="sqrt" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />
                            <Button Grid.Row="2" Grid.Column="2" Content="7" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="7" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="2" Grid.Column="3" Content="8" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="2" Grid.Column="4" Content="9" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="9" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="2" Grid.Column="5" Content="×" Command="{x:Bind ViewModel.OperatorCommand}" CommandParameter="*" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />

                            <!-- Linha 3 -->
                            <Button Grid.Row="3" Content="log" Command="{x:Bind ViewModel.ScientificFunctionCommand}" CommandParameter="log" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />
                            <Button Grid.Row="3" Grid.Column="1" Content="ln" Command="{x:Bind ViewModel.ScientificFunctionCommand}" CommandParameter="ln" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />
                            <Button Grid.Row="3" Grid.Column="2" Content="4" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="3" Grid.Column="3" Content="5" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="3" Grid.Column="4" Content="6" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="3" Grid.Column="5" Content="-" Command="{x:Bind ViewModel.OperatorCommand}" CommandParameter="-" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />

                            <!-- Linha 4 -->
                            <Button Grid.Row="4" Content="x²" Command="{x:Bind ViewModel.ScientificFunctionCommand}" CommandParameter="sqr" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />
                            <Button Grid.Row="4" Grid.Column="1" Content="π" Command="{x:Bind ViewModel.ScientificFunctionCommand}" CommandParameter="pi" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />
                            <Button Grid.Row="4" Grid.Column="2" Content="1" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="4" Grid.Column="3" Content="2" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="4" Grid.Column="4" Content="3" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="4" Grid.Column="5" Content="+" Command="{x:Bind ViewModel.OperatorCommand}" CommandParameter="+" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />

                            <!-- Linha 5 -->
                            <Button Grid.Row="5" Content="e" Command="{x:Bind ViewModel.ScientificFunctionCommand}" CommandParameter="e" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />
                            <Button Grid.Row="5" Grid.Column="1" Content="%" Command="{x:Bind ViewModel.CalculatePercentCommand}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />
                            <Button Grid.Row="5" Grid.Column="2" Content="+/-" Command="{x:Bind ViewModel.NegateCommand}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />
                            <Button Grid.Row="5" Grid.Column="3" Content="0" Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <Button Grid.Row="5" Grid.Column="4" Content="," Command="{x:Bind ViewModel.DigitCommand}" CommandParameter="," HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" />
                            <Button Grid.Row="5" Grid.Column="5" Content="=" Command="{x:Bind ViewModel.EvaluateCommand}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="55" Background="{ThemeResource AccentFillColorDefaultBrush}" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                        </Grid>
                    </Grid>
                </TabViewItem>

                <!-- Modo Física (PRO) -->
                <TabViewItem x:Name="FisicaTab" Header="Física Quântica / Nuclear 🔒">
                    <Grid Padding="24" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Width="600" MaxWidth="700" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Laboratório de Física" Style="{StaticResource SubtitleTextBlockStyle}" />
                            
                            <ComboBox ItemsSource="{x:Bind ViewModel.PhysicsFormulas, Mode=OneWay}" 
                                      SelectedIndex="{x:Bind ViewModel.SelectedPhysicsFormulaIndex, Mode=TwoWay}" 
                                      Header="Selecione a Fórmula" HorizontalAlignment="Stretch" />

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Header="Parâmetro 1 (m, Δs)" Text="{x:Bind ViewModel.PhysicsParam1, Mode=TwoWay}" PlaceholderText="Insira o valor" />
                                <TextBox Grid.Column="1" Header="Parâmetro 2 (a, Δt, v)" Text="{x:Bind ViewModel.PhysicsParam2, Mode=TwoWay}" PlaceholderText="Insira o valor" />
                            </Grid>

                            <Button Content="Calcular Resultado" Command="{x:Bind ViewModel.CalculatePhysicsCommand}" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" />

                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Padding="16" CornerRadius="4">
                                <TextBlock Text="{x:Bind ViewModel.PhysicsResult, Mode=OneWay}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabViewItem>

                <!-- Modo Química (PRO) -->
                <TabViewItem x:Name="QuimicaTab" Header="Química 🔒">
                    <Grid Padding="24" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Width="600" MaxWidth="700" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Laboratório de Química" Style="{StaticResource SubtitleTextBlockStyle}" />
                            
                            <ComboBox ItemsSource="{x:Bind ViewModel.ChemistryFormulas, Mode=OneWay}" 
                                      SelectedIndex="{x:Bind ViewModel.SelectedChemistryFormulaIndex, Mode=TwoWay}" 
                                      Header="Selecione a Fórmula" HorizontalAlignment="Stretch" />

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Header="Parâmetro 1 (v)" Text="{x:Bind ViewModel.ChemParam1, Mode=TwoWay}" PlaceholderText="Insira o valor" />
                                <TextBox Grid.Column="1" Header="Parâmetro 2 (t)" Text="{x:Bind ViewModel.ChemParam2, Mode=TwoWay}" PlaceholderText="Insira o valor" />
                            </Grid>

                            <Button Content="Calcular Química" Command="{x:Bind ViewModel.CalculateChemistryCommand}" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" />

                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Padding="16" CornerRadius="4">
                                <TextBlock Text="{x:Bind ViewModel.ChemResult, Mode=OneWay}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabViewItem>

            </TabView.TabItems>
        </TabView>
    </Grid>
</Page>
