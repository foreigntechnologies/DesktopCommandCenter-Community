<Page
    x:Class="DesktopCommandCenter.UI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:DesktopCommandCenter.UI.ViewModels"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="24">
        <ScrollViewer>
            <StackPanel Spacing="24" MaxWidth="800" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,0,0,16">
                    <TextBlock Text="Configurações" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
                    <Border x:Name="ProBadge" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="4" Padding="8,4" VerticalAlignment="Center" Visibility="Collapsed">
                        <TextBlock Text="PRO" Foreground="White" FontWeight="Bold" FontSize="12" />
                    </Border>
                    <Border x:Name="CommunityBadge" Background="{ThemeResource SystemFillColorNeutralBrush}" CornerRadius="4" Padding="8,4" VerticalAlignment="Center" Visibility="Collapsed">
                        <TextBlock Text="COMMUNITY" Foreground="{ThemeResource TextFillColorPrimaryBrush}" FontWeight="Bold" FontSize="12" />
                    </Border>
                </StackPanel>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="24">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Aparência e Temas" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        
                        <ComboBox Header="Tema do Aplicativo" 
                                  SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}"
                                  Width="300">
                            <ComboBoxItem Content="Claro" />
                            <ComboBoxItem Content="Escuro" />
                            <ComboBoxItem Content="Padrão do Sistema (Contraste)" />
                        </ComboBox>

                        <ComboBox Header="Formato da Hora (Início)" 
                                  SelectedIndex="{x:Bind ViewModel.SelectedTimeFormatIndex, Mode=TwoWay}"
                                  Width="300">
                            <ComboBoxItem Content="24 Horas (HH:mm) - Ex: 15:30" />
                            <ComboBoxItem Content="24 Horas com Segundos (HH:mm:ss) - Ex: 15:30:45" />
                            <ComboBoxItem Content="12 Horas AM/PM (hh:mm tt) - Ex: 03:30 PM" />
                            <ComboBoxItem Content="12 Horas com Segundos (hh:mm:ss tt) - Ex: 03:30:45 PM" />
                        </ComboBox>

                        <ComboBox Header="Formato da Data (Início)" 
                                  SelectedIndex="{x:Bind ViewModel.SelectedDateFormatIndex, Mode=TwoWay}"
                                  Width="300">
                            <ComboBoxItem Content="Longo - Ex: quarta-feira, 10 de junho de 2026" />
                            <ComboBoxItem Content="Curto (dd/MM/yyyy) - Ex: 10/06/2026" />
                            <ComboBoxItem Content="ISO (yyyy-MM-dd) - Ex: 2026-06-10" />
                            <ComboBoxItem Content="Inglês - Ex: Jun 10, 2026" />
                        </ComboBox>
                        
                        <TextBlock Text="O tema Padrão do Sistema respeitará o Alto Contraste caso esteja ativado no Windows." 
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="24">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Teclas de Atalho Global" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="Configure atalhos que funcionam de qualquer lugar do Windows." 
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <ListView ItemsSource="{x:Bind ViewModel.Hotkeys, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:HotkeyConfigItemViewModel">
                                    <Grid Padding="8" Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind DisplayName}" VerticalAlignment="Center" FontWeight="SemiBold" />
                                        
                                        <Button Grid.Column="1"
                                                Click="EditHotkeyButton_Click"
                                                Tag="{Binding}"
                                                HorizontalAlignment="Left"
                                                Width="220"
                                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="12,6">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind CurrentHotkeyDisplay, Mode=OneWay}" 
                                                           VerticalAlignment="Center"
                                                           FontFamily="Consolas"
                                                           FontWeight="SemiBold"
                                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                                <FontIcon Grid.Column="1" Glyph="&#xE70F;" FontSize="12" Margin="8,0,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </Grid>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <ContentDialog x:Name="EditHotkeyDialog"
                       Title="Editar Tecla de Atalho"
                       PrimaryButtonText="OK"
                       CloseButtonText="Cancelar"
                       DefaultButton="Primary"
                       PrimaryButtonClick="EditHotkeyDialog_PrimaryButtonClick"
                       KeyDown="EditHotkeyDialog_KeyDown">
            <StackPanel Spacing="16" Width="400">
                <TextBlock x:Name="HotkeyDialogActionText" Text="Configurar atalho para: [Ação]" Style="{StaticResource BodyTextBlockStyle}" FontWeight="SemiBold" />
                
                <Border BorderThickness="1" BorderBrush="{ThemeResource SystemControlElevationBorderBrush}" CornerRadius="4" Padding="12" Background="{ThemeResource ControlOnImageFillColorDefaultBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="HotkeyPreviewText" Text="Nenhum" FontSize="20" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Limpar" Click="ClearHotkeyButton_Click" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                
                <TextBlock Text="Pressione a nova combinação de teclas desejada (ex: Ctrl + Alt + P) no seu teclado. O diálogo capturará as teclas automaticamente. Pressione ENTER para confirmar." 
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                           TextWrapping="Wrap" FontSize="12" />
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>
