<Page
    x:Class="DesktopCommandCenter.UI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="24">
        <ScrollViewer>
            <StackPanel Spacing="24" MaxWidth="800" HorizontalAlignment="Left">
                <TextBlock Text="Configurações" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16"/>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="24">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Aparência e Temas" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        
                        <ComboBox Header="Tema do Aplicativo" 
                                  SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}"
                                  Width="300">
                            <ComboBoxItem Content="Claro" />
                            <ComboBoxItem Content="Escuro" />
                            <ComboBoxItem Content="Padrão do Sistema (Contraste)" />
                        </ComboBox>
                        
                        <TextBlock Text="O tema Padrão do Sistema respeitará o Alto Contraste caso esteja ativado no Windows." 
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="24">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Teclas de Atalho (Em Breve)" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="Personalização avançada de teclas de atalho estará disponível aqui nas próximas versões." 
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
