<ContentDialog
    x:Class="DesktopCommandCenter.UI.Views.OobeDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DesktopCommandCenter.UI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:DesktopCommandCenter.UI.Helpers"
    mc:Ignorable="d"
    helpers:Translate.Key="Oobe_Title"
    Title="Bem-vindo ao Desktop Command Center!"
    PrimaryButtonText="Continuar">

    <StackPanel Spacing="16" Width="400">
        <TextBlock helpers:Translate.Key="Oobe_Desc" Text="Antes de começarmos, escolha o seu tema preferido:" TextWrapping="Wrap" />
        
        <ComboBox x:Name="ThemeComboBox" SelectedIndex="2" HorizontalAlignment="Stretch">
            <ComboBoxItem helpers:Translate.Key="Oobe_ThemeLight" Content="Claro" />
            <ComboBoxItem helpers:Translate.Key="Oobe_ThemeDark" Content="Escuro" />
            <ComboBoxItem helpers:Translate.Key="Oobe_ThemeSystem" Content="Padrão do Sistema (Contraste)" />
        </ComboBox>
        
        <TextBlock helpers:Translate.Key="Oobe_Hint" Text="Você poderá alterar isso nas Configurações posteriormente." 
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                   TextWrapping="Wrap" />
    </StackPanel>
</ContentDialog>
