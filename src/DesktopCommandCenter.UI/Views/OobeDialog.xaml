<ContentDialog x:Name="OobeTitleElement" x:Class="DesktopCommandCenter.UI.Views.OobeDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="using:DesktopCommandCenter.UI.Views" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" Title="Bem-vindo ao Desktop Command Center!" PrimaryButtonText="Continuar">

    <StackPanel Spacing="16" Width="400">
        <TextBlock x:Name="OobeDescElement" Text="Antes de começarmos, escolha o seu tema preferido:" TextWrapping="Wrap"  />
        
        <ComboBox x:Name="ThemeComboBox" SelectedIndex="2" HorizontalAlignment="Stretch">
            <ComboBoxItem x:Name="OobeThemeLightElement" Content="Claro"  />
            <ComboBoxItem x:Name="OobeThemeDarkElement" Content="Escuro"  />
            <ComboBoxItem x:Name="OobeThemeSystemElement" Content="Padrão do Sistema (Contraste)"  />
        </ComboBox>
        
        <TextBlock x:Name="OobeHintElement" Text="Você poderá alterar isso nas Configurações posteriormente." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"  />
    </StackPanel>
</ContentDialog>
