<Page
    x:Name="RootPage"
    x:Class="DesktopCommandCenter.UI.Views.ClipboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:DesktopCommandCenter.Domain.Entities"
    xmlns:converters="using:DesktopCommandCenter.UI.Converters"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:TypeToVisibilityConverter x:Key="TextVisibilityConverter" TargetType="Text" />
        <converters:TypeToVisibilityConverter x:Key="ImageVisibilityConverter" TargetType="Image" />
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Smart Clipboard" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Limpar Histórico" Command="{x:Bind ViewModel.ClearHistoryCommand}" />
        </Grid>

        <ProgressRing Grid.Row="1" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center" />

        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ClipboardItem">
                    <Grid Padding="16" Margin="0,0,0,12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" MaxLines="3" VerticalAlignment="Center" Visibility="{x:Bind Type, Converter={StaticResource TextVisibilityConverter}}" />
                        <Image Source="{Binding ImagePath}" MaxHeight="150" HorizontalAlignment="Left" Stretch="Uniform" Visibility="{x:Bind Type, Converter={StaticResource ImageVisibilityConverter}}" />
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <Button ToolTipService.ToolTip="Copiar novamente" Content="&#xE8C8;" FontFamily="Segoe Fluent Icons" Background="Transparent" BorderBrush="Transparent"/>
                            <Button ToolTipService.ToolTip="Excluir" Content="&#xE74D;" FontFamily="Segoe Fluent Icons" Background="Transparent" BorderBrush="Transparent" Foreground="Red" Command="{Binding DataContext.DeleteItemCommand, ElementName=RootPage}" CommandParameter="{Binding}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
