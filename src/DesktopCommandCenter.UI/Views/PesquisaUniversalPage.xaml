<Page
    x:Class="DesktopCommandCenter.UI.Views.PesquisaUniversalPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:DesktopCommandCenter.UI.ViewModels"
    Background="Transparent">
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Spacing="16" HorizontalAlignment="Center" Margin="0,40,0,32">
            <TextBlock Text="Pesquisa Universal" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" />
            
            <TextBox Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     PlaceholderText="Pesquise por ferramentas, notas ou comandos..." 
                     FontSize="24" Width="600" Padding="16" CornerRadius="8" />
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Results, Mode=OneWay}" 
                  HorizontalAlignment="Center" Width="600" SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:SearchResultItem">
                    <Grid Padding="16" Margin="0,4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <FontIcon Glyph="&#xE71E;" FontSize="24" Foreground="{ThemeResource SystemAccentColor}"/>
                            <StackPanel>
                                <TextBlock Text="{x:Bind Title}" FontWeight="Bold" FontSize="16" />
                                <TextBlock Text="{x:Bind Description}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
