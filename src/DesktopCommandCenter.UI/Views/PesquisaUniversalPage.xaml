<Page
    x:Class="DesktopCommandCenter.UI.Views.PesquisaUniversalPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:DesktopCommandCenter.UI.ViewModels"
    Background="Transparent">
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Spacing="16" HorizontalAlignment="Stretch" Margin="0,20,0,32">
            <TextBlock x:Name="SearchPageTitleElement" Text="Pesquisa Universal Avançada" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center"  />
            
            <TextBox x:Name="SearchInputPlaceholderElement" Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Pesquise apps, arquivos, configs ou digite > para comandos e = para cálculos..." 
                     FontSize="24" MaxWidth="800" HorizontalAlignment="Stretch" Padding="16" CornerRadius="8" />
        </StackPanel>

        <Grid Grid.Row="1" MaxWidth="1000" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Lista de Resultados -->
            <ListView Grid.Column="0" ItemsSource="{x:Bind ViewModel.Results, Mode=OneWay}" 
                      SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
                      SelectionMode="Single"
                      IsItemClickEnabled="True" ItemClick="ListView_ItemClick"
                      Margin="0,0,16,0">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:SearchResultItem">
                        <Grid Padding="16" Margin="0,4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <FontIcon Glyph="{x:Bind IconGlyph}" FontSize="24" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                <StackPanel>
                                    <TextBlock Text="{x:Bind Title}" FontWeight="Bold" FontSize="16" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind Description}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Painel de Preview -->
            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="24" Visibility="{x:Bind ViewModel.PreviewVisibility, Mode=OneWay}">
                <StackPanel Spacing="16" VerticalAlignment="Center">
                    <FontIcon Glyph="{x:Bind ViewModel.SelectedItem.IconGlyph, Mode=OneWay}" FontSize="64" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,16" />
                    
                    <TextBlock Text="{x:Bind ViewModel.SelectedItem.Title, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                    
                    <TextBlock Text="{x:Bind ViewModel.SelectedItem.Type, Mode=OneWay}" FontSize="14" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    
                    <TextBlock Text="{x:Bind ViewModel.SelectedItem.Description, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                    
                    <TextBlock Text="{x:Bind ViewModel.SelectedItem.ActionPath, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,16,0,0" />
                    
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" Margin="0,24,0,0">
                        <Button x:Name="BtnOpen" Content="Abrir / Executar" Style="{StaticResource AccentButtonStyle}" Click="BtnOpen_Click"  />
                        <Button x:Name="BtnSendToAI" Content="Enviar para IA" Click="BtnSendToAI_Click"  />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
