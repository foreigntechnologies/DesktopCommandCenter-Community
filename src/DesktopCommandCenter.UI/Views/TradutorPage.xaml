<Page
    x:Class="DesktopCommandCenter.UI.Views.TradutorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TranslatorPageTitleElement" Text="Tradutor" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16" />

        <Grid Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid ColumnSpacing="16" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <ComboBox ItemsSource="{x:Bind ViewModel.SourceLanguages, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SourceLanguage, Mode=TwoWay}" HorizontalAlignment="Stretch"/>

                <Button Grid.Column="1" Content="â‡„" Command="{x:Bind ViewModel.SwapLanguagesCommand}" Background="Transparent" BorderThickness="0" FontSize="20"/>

                <ComboBox Grid.Column="2" ItemsSource="{x:Bind ViewModel.TargetLanguages, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.TargetLanguage, Mode=TwoWay}" HorizontalAlignment="Stretch"/>
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <Grid>
                    <TextBox x:Name="TranslatorSourceTextElement" Text="{x:Bind ViewModel.SourceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" PlaceholderText="Digite ou cole o texto aqui..." MinHeight="300" Padding="12,12,12,48" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12" Spacing="4">
                        <Button Command="{x:Bind ViewModel.PasteSourceCommand}" Background="Transparent" BorderThickness="0">
                            <ToolTipService.ToolTip>
                                <ToolTip x:Name="TranslatorBtnPasteElement" Content="Colar"  />
                            </ToolTipService.ToolTip>
                            <FontIcon Glyph="&#xE77F;" FontSize="14"/>
                        </Button>
                        <Button Command="{x:Bind ViewModel.CopySourceCommand}" Background="Transparent" BorderThickness="0">
                            <ToolTipService.ToolTip>
                                <ToolTip x:Name="TranslatorBtnCopyElement" Content="Copiar"  />
                            </ToolTipService.ToolTip>
                            <FontIcon Glyph="&#xE8C8;" FontSize="14"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1">
                    <TextBox x:Name="TranslatorTargetTextElement" Text="{x:Bind ViewModel.TranslatedText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" MinHeight="300" Padding="12,12,12,48" PlaceholderText="TraduÃ§Ã£o..." />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12" Spacing="4">
                        <Button Command="{x:Bind ViewModel.PasteTranslatedCommand}" Background="Transparent" BorderThickness="0">
                            <ToolTipService.ToolTip>
                                <ToolTip x:Name="TranslatorBtnPasteTargetElement" Content="Colar"  />
                            </ToolTipService.ToolTip>
                            <FontIcon Glyph="&#xE77F;" FontSize="14"/>
                        </Button>
                        <Button Command="{x:Bind ViewModel.CopyTranslatedCommand}" Background="Transparent" BorderThickness="0">
                            <ToolTipService.ToolTip>
                                <ToolTip x:Name="TranslatorBtnCopyTargetElement" Content="Copiar"  />
                            </ToolTipService.ToolTip>
                            <FontIcon Glyph="&#xE8C8;" FontSize="14"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>

