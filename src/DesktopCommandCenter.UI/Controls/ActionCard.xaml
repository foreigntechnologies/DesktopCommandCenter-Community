<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DesktopCommandCenter.UI.Controls.ActionCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Button x:Name="RootButton" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <FontIcon Grid.Column="0" Glyph="{x:Bind IconGlyph, Mode=OneWay}" FontSize="20" Margin="0,0,16,0" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center" />
            
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind Title, Mode=OneWay}" FontWeight="SemiBold" FontSize="14" />
                <TextBlock Text="{x:Bind Description, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
            </StackPanel>

            <FontIcon Grid.Column="2" Glyph="&#xE974;" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
        </Grid>
    </Button>
</UserControl>
