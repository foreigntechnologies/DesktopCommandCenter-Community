<Page
    x:Class="DesktopCommandCenter.UI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="Transparent">
        <NavigationView x:Name="AppNavigationView" 
                        IsBackButtonVisible="Collapsed" 
                        PaneDisplayMode="Left"
                        ItemInvoked="OnItemInvoked"
                        Background="Transparent">
            
            <NavigationView.MenuItems>
                <!-- FREE MODULES -->
                <NavigationViewItem x:Name="NavDashboard" Tag="Dashboard" Icon="Home" Content="Dashboard"  />
                <NavigationViewItem x:Name="NavProcessManager" Content="Processos" Tag="ProcessManager" Icon="List"  />
                <NavigationViewItem x:Name="NavNotes" Tag="Notes" Icon="Document" Content="Notes"  />
                <NavigationViewItemHeader x:Name="HeaderSysUtils" Content="Utilitários do Sistema"  />
                <NavigationViewItem x:Name="NavSystemUpdates" Tag="SystemUpdates" Icon="Sync" Content="Update Center"  />
                <NavigationViewItem x:Name="NavColorPicker" Tag="ColorPicker" Content="Color Picker" Icon="Highlight"  />
                <NavigationViewItem x:Name="NavAwake" Tag="Awake" Content="Awake (Manter PC Ativo)" Icon="Street"  />
                <NavigationViewItem x:Name="NavCliCommands" Tag="CliCommands" Content="Comandos CLI">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE756;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavFutureShell" Tag="FutureShell" Content="FutureShell">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE943;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavClipboard" Tag="Clipboard" Icon="Copy" Content="Clipboard"  />
                <NavigationViewItem x:Name="NavTimer" Tag="Temporizador" Icon="Clock" Content="Temporizador"  />
                <NavigationViewItem x:Name="NavSearch" Tag="PesquisaUniversal" Icon="Find" Content="Pesquisa Universal"  />
                <NavigationViewItem x:Name="NavCapture" Tag="Captura" Icon="Camera" Content="Captura de Tela"  />
                <NavigationViewItem x:Name="NavTranslator" Tag="Tradutor" Icon="Character" Content="Tradutor"  />

                <!-- PRO MODULES HEADER -->
                <NavigationViewItemHeader x:Name="HeaderPro" Content="Recursos PRO (IA &amp; Automação)"  />
                <NavigationViewItem x:Name="NavIALocal" Tag="IALocal" Icon="PreviewLink" Content="ChatFT"  />
                <NavigationViewItem x:Name="NavPrompts" Tag="Prompts" Icon="Library" Content="Biblioteca de Prompts"  />
                <NavigationViewItem x:Name="NavAutomations" Tag="Automacoes" Icon="RepeatAll" Content="Automações"  />
                <NavigationViewItem x:Name="NavMarketplace" Tag="Marketplace" Icon="Shop" Content="Marketplace e Plugins"  />
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Name="NavAuth" Tag="Auth" Icon="Contact" Content="Minha Conta"  />
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" Margin="24">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition/>
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </NavigationView>

        <ContentDialog x:Name="FirstLaunchLanguageDialog"
                       Title="Select Language / Selecione o Idioma / Seleccione el Idioma"
                       PrimaryButtonText="OK"
                       IsPrimaryButtonEnabled="False"
                       PrimaryButtonClick="FirstLaunchLanguageDialog_PrimaryButtonClick">
            <StackPanel Spacing="10">
                <TextBlock Text="Welcome! Please choose your preferred language for Desktop Command Center:" TextWrapping="Wrap" />
                <ComboBox x:Name="CmbFirstLaunchLanguage" Width="300" SelectionChanged="CmbFirstLaunchLanguage_SelectionChanged">
                    <ComboBoxItem Content="Português - Brasil" Tag="pt-BR" />
                    <ComboBoxItem Content="English" Tag="en-US" />
                    <ComboBoxItem Content="Español" Tag="es-ES" />
                </ComboBox>
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>
