<Page
    x:Class="DesktopCommandCenter.UI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:DesktopCommandCenter.UI.Helpers"
    mc:Ignorable="d">

    <Grid Background="Transparent">
        <NavigationView x:Name="AppNavigationView" 
                        IsBackButtonVisible="Collapsed" 
                        PaneDisplayMode="Left"
                        ItemInvoked="OnItemInvoked"
                        Background="Transparent">
            
            <NavigationView.MenuItems>
                <NavigationViewItem Tag="Dashboard" Icon="Home" Content="Dashboard" />
                <NavigationViewItem Tag="Notes" Icon="Document" Content="Notes" />
                <NavigationViewItem Tag="Clipboard" Icon="Copy" Content="Clipboard" />
                <NavigationViewItem Tag="ColorPicker" Icon="Highlight" Content="Color Picker" />
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Tag="Auth" Icon="Contact" Content="Minha Conta (Login)" />
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" Margin="24">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition/>
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </NavigationView>
    </Grid>
</Page>
