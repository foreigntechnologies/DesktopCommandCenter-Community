<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="DesktopCommandCenter.UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DesktopCommandCenter.UI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <!-- Fundo Translúcido e Escuro -->
                    <SolidColorBrush x:Key="WindowBackgroundColor" Color="Transparent" />
                    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="Transparent" />
                    
                    <!-- Cores de Destaque (Accent) Futuristas (Ciano Neon) -->
                    <Color x:Key="SystemAccentColor">#00E5FF</Color>
                    <Color x:Key="SystemAccentColorLight1">#40EFFF</Color>
                    <Color x:Key="SystemAccentColorLight2">#80F5FF</Color>
                    <Color x:Key="SystemAccentColorLight3">#BFFFFF</Color>
                    <Color x:Key="SystemAccentColorDark1">#00B8CC</Color>
                    <Color x:Key="SystemAccentColorDark2">#008999</Color>
                    <Color x:Key="SystemAccentColorDark3">#005B66</Color>
                    
                    <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="{StaticResource SystemAccentColor}" />
                    
                    <!-- Fundo de Cards Semi-Transparentes -->
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1AFFFFFF" />
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#33FFFFFF" />
                    <CornerRadius x:Key="CardCornerRadius">12</CornerRadius>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>

